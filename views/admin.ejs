<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YOSHIDA - Panel de Administración</title>
    <!-- Tailwind CSS for utility foundation -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=SF+Pro+Display:wght@300;400;500;600;700&display=swap');

        body {
            font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: linear-gradient(135deg, #0f172a, #1e1b4b, #311042);
            background-attachment: fixed;
            min-height: 100vh;
            transition: background 0.5s ease;
        }

        /* Light mode overrides */
        body.light-theme {
            background: linear-gradient(135deg, #f1f5f9, #e0e7ff, #fae8ff);
            color: #1e293b;
        }

        /* Glassmorphism styling */
        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body.light-theme .glass-card {
            background: rgba(255, 255, 255, 0.6);
            border: 1px solid rgba(0, 0, 0, 0.06);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.05);
        }

        .glass-card:hover {
            border-color: rgba(255, 255, 255, 0.15);
            box-shadow: 0 12px 40px 0 rgba(0, 0, 0, 0.4);
        }

        body.light-theme .glass-card:hover {
            border-color: rgba(0, 0, 0, 0.1);
            box-shadow: 0 12px 40px 0 rgba(31, 38, 135, 0.08);
        }

        /* Nav Tab active states */
        .tab-btn {
            position: relative;
            transition: all 0.3s ease;
        }
        .tab-btn.active {
            color: #ec4899;
            text-shadow: 0 0 10px rgba(236, 72, 153, 0.3);
        }
        .tab-btn.active::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 15%;
            width: 70%;
            height: 3px;
            background: linear-gradient(90deg, #ec4899, #8b5cf6);
            border-radius: 9999px;
        }

        /* IOS Switch styling */
        .ios-switch {
            position: relative;
            display: inline-block;
            width: 50px;
            height: 28px;
        }
        .ios-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }
        .ios-slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(255, 255, 255, 0.1);
            transition: .4s;
            border-radius: 34px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        body.light-theme .ios-slider {
            background-color: #cbd5e1;
            border: 1px solid rgba(0, 0, 0, 0.05);
        }
        .ios-slider:before {
            position: absolute;
            content: "";
            height: 22px;
            width: 22px;
            left: 2px;
            bottom: 2px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }
        input:checked + .ios-slider {
            background: linear-gradient(135deg, #ec4899, #8b5cf6);
        }
        input:checked + .ios-slider:before {
            transform: translateX(22px);
        }

        /* Scrollbars styling */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(0,0,0,0.1);
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        /* Shimmer effect for status */
        @keyframes pulse-glow {
            0%, 100% { opacity: 0.6; transform: scale(1); }
            50% { opacity: 1; transform: scale(1.1); }
        }
        .pulse-dot {
            animation: pulse-glow 2s infinite ease-in-out;
        }
    </style>
</head>
<body class="text-white antialiased pb-20">

    <!-- TOP HEADER -->
    <header class="w-full max-w-6xl mx-auto px-4 pt-6 pb-2 flex justify-between items-center">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-pink-500 to-purple-600 flex items-center justify-center shadow-lg shadow-pink-500/20">
                <i class="fa-solid fa-robot text-lg text-white"></i>
            </div>
            <div>
                <h1 class="font-bold text-xl tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-pink-500 via-purple-400 to-indigo-400">YOSHIDA Bot</h1>
                <p class="text-xs text-gray-400 flex items-center gap-1.5">
                    <span class="w-2.5 h-2.5 rounded-full bg-green-500 pulse-dot inline-block"></span>
                    Admin Panel v1.2
                </p>
            </div>
        </div>

        <div class="flex items-center gap-4">
            <!-- Theme Toggle Button -->
            <button id="themeToggle" class="p-2.5 rounded-full glass-card hover:scale-105 active:scale-95 flex items-center justify-center" title="Cambiar tema">
                <i class="fa-solid fa-moon text-lg text-pink-400" id="themeIcon"></i>
            </button>

            <div class="text-sm font-medium glass-card px-4 py-2 rounded-full hidden sm:flex items-center gap-2">
                <i class="fa-solid fa-link text-green-400"></i>
                <span>Render: Activo</span>
            </div>
        </div>
    </header>

    <!-- MAIN BODY NAV & CONTENT -->
    <main class="w-full max-w-6xl mx-auto px-4 mt-4 grid grid-cols-1 md:grid-cols-4 gap-6">

        <!-- SIDE NAVIGATION BAR (IOS STYLE) -->
        <nav class="md:col-span-1 flex md:flex-col overflow-x-auto md:overflow-x-visible pb-2 md:pb-0 gap-2 scrollbar-none">
            <button onclick="switchTab('personality')" id="tab-personality" class="tab-btn active flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-medium w-full min-w-[140px] md:min-w-0">
                <i class="fa-solid fa-brain text-pink-500 text-lg"></i>
                <span>Personalidad</span>
            </button>
            <button onclick="switchTab('rules')" id="tab-rules" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-medium w-full min-w-[140px] md:min-w-0">
                <i class="fa-solid fa-scroll text-purple-500 text-lg"></i>
                <span>Reglas y Leyes</span>
            </button>
            <button onclick="switchTab('contacts')" id="tab-contacts" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-medium w-full min-w-[140px] md:min-w-0">
                <i class="fa-solid fa-address-book text-indigo-500 text-lg"></i>
                <span>Contactos</span>
            </button>
            <button onclick="switchTab('stats')" id="tab-stats" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-medium w-full min-w-[140px] md:min-w-0">
                <i class="fa-solid fa-chart-pie text-cyan-500 text-lg"></i>
                <span>Monitoreo</span>
            </button>
            <button onclick="switchTab('config')" id="tab-config" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-medium w-full min-w-[140px] md:min-w-0">
                <i class="fa-solid fa-gears text-amber-500 text-lg"></i>
                <span>Bot Config</span>
            </button>
            <button onclick="switchTab('logs')" id="tab-logs" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-medium w-full min-w-[140px] md:min-w-0">
                <i class="fa-solid fa-list-ul text-teal-500 text-lg"></i>
                <span>Logs Recientes</span>
            </button>
        </nav>

        <!-- CONTENT AREA panels -->
        <section class="md:col-span-3">

            <!-- TAB: PERSONALIDAD -->
            <div id="panel-personality" class="tab-panel space-y-6">
                <div class="glass-card p-6 rounded-3xl">
                    <h2 class="text-xl font-semibold mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-brain text-pink-500"></i>
                        Personalidad de la IA
                    </h2>
                    <form id="personalityForm" class="space-y-4" onsubmit="savePersonality(event)">
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1.5">Personalidad Principal (System Instruction)</label>
                            <textarea id="personality" name="personality" rows="4" class="w-full rounded-2xl bg-black/30 border border-white/10 px-4 py-3 text-white focus:border-pink-500 focus:ring-0 resize-none outline-none transition-colors"><%= aiConfig.personality %></textarea>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-400 mb-1.5">Tono de Conversación</label>
                                <input type="text" id="tone" name="tone" value="<%= aiConfig.tone %>" class="w-full rounded-2xl bg-black/30 border border-white/10 px-4 py-3 text-white focus:border-pink-500 outline-none transition-colors">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-400 mb-1.5">Idioma Principal</label>
                                <select id="language" name="language" class="w-full rounded-2xl bg-black/30 border border-white/10 px-4 py-3 text-white focus:border-pink-500 outline-none transition-colors appearance-none">
                                    <option value="es" <%= aiConfig.language === 'es' ? 'selected' : '' %>>Español</option>
                                    <option value="en" <%= aiConfig.language === 'en' ? 'selected' : '' %>>English</option>
                                    <option value="id" <%= aiConfig.language === 'id' ? 'selected' : '' %>>Indonesian</option>
                                    <option value="pt" <%= aiConfig.language === 'pt' ? 'selected' : '' %>>Portuguese</option>
                                </select>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-400 mb-1.5">Longitud Máxima de Respuesta (Tokens)</label>
                                <input type="number" id="maxLength" name="maxLength" value="<%= aiConfig.maxLength %>" class="w-full rounded-2xl bg-black/30 border border-white/10 px-4 py-3 text-white focus:border-pink-500 outline-none">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-400 mb-1.5">Creatividad / Temperatura (0.0 - 1.0)</label>
                                <input type="number" step="0.1" id="creativity" name="creativity" value="<%= aiConfig.creativity %>" class="w-full rounded-2xl bg-black/30 border border-white/10 px-4 py-3 text-white focus:border-pink-500 outline-none">
                            </div>
                        </div>

                        <div class="border-t border-white/5 pt-4 space-y-4">
                            <h3 class="text-sm font-semibold tracking-wider text-purple-400 uppercase">Proveedor y Modelo de IA</h3>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-medium text-gray-400 mb-1.5">Proveedor</label>
                                    <select id="provider" name="provider" onchange="updateProviderModels()" class="w-full rounded-2xl bg-black/30 border border-white/10 px-4 py-3 text-white focus:border-pink-500 outline-none transition-colors">
                                        <option value="gemini" <%= aiConfig.provider === 'gemini' ? 'selected' : '' %>>Google Gemini</option>
                                        <option value="openrouter" <%= aiConfig.provider === 'openrouter' ? 'selected' : '' %>>OpenRouter</option>
                                        <option value="grok" <%= aiConfig.provider === 'grok' ? 'selected' : '' %>>xAI Grok</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-400 mb-1.5">Modelo Personalizado</label>
                                    <input type="text" id="model" name="model" value="<%= aiConfig.model %>" placeholder="ej: gemini-2.0-flash" class="w-full rounded-2xl bg-black/30 border border-white/10 px-4 py-3 text-white focus:border-pink-500 outline-none">
                                </div>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-400 mb-1.5">API Key del Proveedor (Opcional, si está vacía usa env variables)</label>
                                <input type="password" id="apiKey" name="apiKey" value="<%= aiConfig.apiKey %>" placeholder="Escribe tu API Key aquí..." class="w-full rounded-2xl bg-black/30 border border-white/10 px-4 py-3 text-white focus:border-pink-500 outline-none">
                            </div>
                        </div>

                        <div class="border-t border-white/5 pt-4">
                            <div class="flex items-center justify-between">
                                <div>
                                    <h3 class="text-sm font-semibold text-indigo-400">Capacidad MCP (Model Context Protocol)</h3>
                                    <p class="text-xs text-gray-400">Permite al modelo usar herramientas y servidores MCP externos.</p>
                                </div>
                                <label class="ios-switch">
                                    <input type="checkbox" id="mcpEnabled" name="mcpEnabled" <%= aiConfig.mcpEnabled ? 'checked' : '' %>>
                                    <span class="ios-slider"></span>
                                </label>
                            </div>

                            <div id="mcpServersSection" class="mt-4 space-y-3 <%= aiConfig.mcpEnabled ? '' : 'hidden' %>">
                                <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider">Servidores MCP Configurados</label>
                                <div id="mcpServersList" class="space-y-2">
                                    <!-- Dynamic list of MCP servers -->
                                </div>
                                <div class="flex gap-2">
                                    <input type="text" id="newMcpName" placeholder="Nombre (ej: Postgres Server)" class="w-1/3 rounded-xl bg-black/30 border border-white/10 px-3 py-2 text-sm text-white focus:border-pink-500 outline-none">
                                    <input type="text" id="newMcpUrl" placeholder="URL HTTP/SSE Endpoint" class="w-2/3 rounded-xl bg-black/30 border border-white/10 px-3 py-2 text-sm text-white focus:border-pink-500 outline-none">
                                    <button type="button" onclick="addMcpServer()" class="px-4 py-2 bg-gradient-to-tr from-pink-500 to-purple-600 rounded-xl font-medium text-sm hover:opacity-90 active:scale-95 transition-all flex items-center justify-center">
                                        <i class="fa-solid fa-plus"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="pt-4 flex justify-end">
                            <button type="submit" class="w-full sm:w-auto px-8 py-3.5 bg-gradient-to-r from-pink-500 via-purple-500 to-indigo-500 hover:opacity-90 active:scale-[0.98] transition-all rounded-2xl font-semibold shadow-lg shadow-pink-500/10">
                                Guardar Personalidad
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- TAB: REGLAS -->
            <div id="panel-rules" class="tab-panel space-y-6 hidden">
                <div class="glass-card p-6 rounded-3xl">
                    <h2 class="text-xl font-semibold mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-scroll text-purple-500"></i>
                        Leyes y Reglas del Bot
                    </h2>

                    <!-- Rule list -->
                    <div id="rulesList" class="space-y-3 mb-6">
                        <!-- Dynamic content -->
                    </div>

                    <div class="border-t border-white/5 pt-4">
                        <h3 class="text-sm font-semibold text-gray-300 mb-3">Añadir Nueva Regla</h3>
                        <form id="ruleForm" class="grid grid-cols-1 sm:grid-cols-3 gap-3 items-end" onsubmit="addRule(event)">
                            <div class="sm:col-span-2">
                                <label class="block text-xs text-gray-400 mb-1">Descripción de la Regla</label>
                                <input type="text" id="ruleText" required placeholder="ej: No digas garabatos bajo ninguna circunstancia..." class="w-full rounded-2xl bg-black/30 border border-white/10 px-4 py-3 text-sm text-white focus:border-pink-500 outline-none">
                            </div>
                            <div class="flex gap-2">
                                <div class="w-full">
                                    <label class="block text-xs text-gray-400 mb-1">Prioridad</label>
                                    <select id="rulePriority" class="w-full rounded-2xl bg-black/30 border border-white/10 px-3 py-3 text-sm text-white focus:border-pink-500 outline-none">
                                        <option value="alta">Alta</option>
                                        <option value="media">Media</option>
                                        <option value="baja">Baja</option>
                                    </select>
                                </div>
                                <button type="submit" class="px-5 py-3 bg-gradient-to-tr from-purple-500 to-pink-500 rounded-2xl font-bold hover:opacity-90 active:scale-95 transition-all flex items-center justify-center">
                                    <i class="fa-solid fa-plus text-base"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- TAB: CONTACTOS -->
            <div id="panel-contacts" class="tab-panel space-y-6 hidden">
                <div class="glass-card p-6 rounded-3xl">
                    <h2 class="text-xl font-semibold mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-address-book text-indigo-500"></i>
                        Gestión de Prospección / Contactos
                    </h2>

                    <!-- Add proactive contact -->
                    <form id="contactForm" class="grid grid-cols-1 sm:grid-cols-3 gap-3 items-end mb-6" onsubmit="addContact(event)">
                        <div>
                            <label class="block text-xs text-gray-400 mb-1">Número de Teléfono (con código de país)</label>
                            <input type="text" id="contactNumber" required placeholder="ej: 521234567890" class="w-full rounded-2xl bg-black/30 border border-white/10 px-4 py-3 text-sm text-white focus:border-indigo-500 outline-none">
                        </div>
                        <div>
                            <label class="block text-xs text-gray-400 mb-1">Nombre / Mensaje Personalizado</label>
                            <input type="text" id="contactMessage" placeholder="Mensaje único o nombre..." class="w-full rounded-2xl bg-black/30 border border-white/10 px-4 py-3 text-sm text-white focus:border-indigo-500 outline-none">
                        </div>
                        <button type="submit" class="w-full py-3.5 bg-gradient-to-r from-indigo-500 to-purple-600 rounded-2xl font-semibold hover:opacity-90 active:scale-[0.98] transition-all text-sm flex items-center justify-center gap-2">
                            <i class="fa-solid fa-user-plus"></i>
                            Añadir Contacto
                        </button>
                    </form>

                    <!-- Contact list -->
                    <div class="border-t border-white/5 pt-4">
                        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-4 gap-3">
                            <h3 class="text-sm font-semibold text-gray-300">Lista de Campañas</h3>
                            <button onclick="triggerProactiveMessages()" class="px-5 py-2.5 bg-green-500 hover:bg-green-600 text-white rounded-2xl text-xs font-bold transition-all shadow-lg shadow-green-500/10 flex items-center gap-2">
                                <i class="fa-solid fa-paper-plane"></i>
                                Enviar Mensajes Pendientes
                            </button>
                        </div>

                        <div class="overflow-x-auto rounded-2xl border border-white/5 bg-black/10">
                            <table class="w-full text-left text-sm">
                                <thead class="bg-white/5 text-gray-400 uppercase text-xs font-semibold">
                                    <tr>
                                        <th class="px-4 py-3">Número</th>
                                        <th class="px-4 py-3">Mensaje Personalizado</th>
                                        <th class="px-4 py-3">Estado</th>
                                        <th class="px-4 py-3 text-right">Acción</th>
                                    </tr>
                                </thead>
                                <tbody id="contactsTableBody" class="divide-y divide-white/5">
                                    <!-- Dynamic rows -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TAB: MONITOREO/ESTADISTICAS -->
            <div id="panel-stats" class="tab-panel space-y-6 hidden">
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                    <div class="glass-card p-5 rounded-3xl">
                        <p class="text-xs text-gray-400 font-semibold uppercase tracking-wider">Total de Usuarios</p>
                        <h3 class="text-3xl font-bold mt-2" id="statTotalUsers">0</h3>
                        <div class="text-xs text-green-400 mt-1.5 flex items-center gap-1">
                            <i class="fa-solid fa-caret-up"></i>
                            <span>Crecimiento orgánico</span>
                        </div>
                    </div>
                    <div class="glass-card p-5 rounded-3xl">
                        <p class="text-xs text-gray-400 font-semibold uppercase tracking-wider">Usuarios Activos (Hoy)</p>
                        <h3 class="text-3xl font-bold mt-2" id="statActiveUsers">0</h3>
                        <div class="text-xs text-indigo-400 mt-1.5 flex items-center gap-1">
                            <i class="fa-solid fa-clock"></i>
                            <span>Últimas 24 horas</span>
                        </div>
                    </div>
                    <div class="glass-card p-5 rounded-3xl">
                        <p class="text-xs text-gray-400 font-semibold uppercase tracking-wider">Mensajes Procesados</p>
                        <h3 class="text-3xl font-bold mt-2" id="statMsgProcessed">0</h3>
                        <div class="text-xs text-pink-400 mt-1.5 flex items-center gap-1">
                            <i class="fa-solid fa-bolt"></i>
                            <span>Total de interacciones</span>
                        </div>
                    </div>
                    <div class="glass-card p-5 rounded-3xl">
                        <p class="text-xs text-gray-400 font-semibold uppercase tracking-wider">Tasa de Respuesta</p>
                        <h3 class="text-3xl font-bold mt-2" id="statResponseRate">100%</h3>
                        <div class="text-xs text-cyan-400 mt-1.5 flex items-center gap-1">
                            <i class="fa-solid fa-circle-check"></i>
                            <span>Éxito de entregas</span>
                        </div>
                    </div>
                </div>

                <!-- Graph card -->
                <div class="glass-card p-6 rounded-3xl">
                    <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-chart-line text-cyan-500"></i>
                        Actividad de Mensajes (Últimos 7 Días)
                    </h2>
                    <div class="h-64 flex items-end justify-between gap-2 pt-6 pb-2" id="activityGraph">
                        <!-- Dynamic SVG or CSS Bar Graph -->
                    </div>
                </div>
            </div>

            <!-- TAB: CONFIGURACION BOT -->
            <div id="panel-config" class="tab-panel space-y-6 hidden">
                <div class="glass-card p-6 rounded-3xl">
                    <h2 class="text-xl font-semibold mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-gears text-amber-500"></i>
                        Configuración General del Bot
                    </h2>
                    <form id="botConfigForm" class="space-y-4" onsubmit="saveBotConfig(event)">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-400 mb-1.5">Nombre del Bot</label>
                                <input type="text" id="botName" name="botName" value="<%= botName %>" class="w-full rounded-2xl bg-black/30 border border-white/10 px-4 py-3 text-white focus:border-amber-500 outline-none">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-400 mb-1.5">Comando de Activación (Prefix)</label>
                                <input type="text" id="botPrefix" name="botPrefix" value="<%= prefix %>" placeholder="ej: !ai o ." class="w-full rounded-2xl bg-black/30 border border-white/10 px-4 py-3 text-white focus:border-amber-500 outline-none">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 border-t border-white/5 pt-4">
                            <div class="flex items-center justify-between py-2">
                                <div>
                                    <h3 class="text-sm font-semibold text-gray-300">Estado del Bot</h3>
                                    <p class="text-xs text-gray-400">¿Responder a solicitudes?</p>
                                </div>
                                <label class="ios-switch">
                                    <input type="checkbox" id="botStatus" name="botStatus" <%= botStatus ? 'checked' : '' %>>
                                    <span class="ios-slider"></span>
                                </label>
                            </div>
                            <div class="flex items-center justify-between py-2">
                                <div>
                                    <h3 class="text-sm font-semibold text-gray-300">Activar Pairing Code</h3>
                                    <p class="text-xs text-gray-400">Iniciar sesión mediante código numérico</p>
                                </div>
                                <label class="ios-switch">
                                    <input type="checkbox" id="pairingState" name="pairingState" <%= pairingState ? 'checked' : '' %>>
                                    <span class="ios-slider"></span>
                                </label>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1.5">Número de Vinculación (PAIRING_NUMBER)</label>
                            <input type="text" id="pairingNumber" name="pairingNumber" value="<%= pairingNumber %>" placeholder="ej: 521234567890" class="w-full rounded-2xl bg-black/30 border border-white/10 px-4 py-3 text-white focus:border-amber-500 outline-none">
                        </div>

                        <!-- PAIRING CODE VIEW -->
                        <div id="pairingCodeCard" class="bg-pink-500/10 border border-pink-500/20 p-5 rounded-2xl <%= pairingCode ? '' : 'hidden' %>">
                            <p class="text-xs text-pink-400 font-bold uppercase tracking-wider mb-2">Código de Vinculación Generado</p>
                            <div class="flex items-center justify-between">
                                <span class="text-2xl font-mono tracking-widest font-extrabold text-pink-300" id="pairingCodeDisplay"><%= pairingCode %></span>
                                <button type="button" onclick="copyPairingCode()" class="px-4 py-2 bg-pink-500 hover:bg-pink-600 rounded-xl font-bold text-xs transition-colors flex items-center gap-1.5">
                                    <i class="fa-solid fa-copy"></i> Copiar
                                </button>
                            </div>
                            <p class="text-[11px] text-gray-400 mt-2">Introduce este código en WhatsApp Web para iniciar la conexión del Bot.</p>
                        </div>

                        <div class="pt-4 flex flex-col sm:flex-row gap-3">
                            <button type="submit" class="w-full sm:w-auto px-8 py-3.5 bg-gradient-to-r from-amber-500 to-orange-500 rounded-2xl font-bold shadow-lg shadow-amber-500/10 hover:opacity-90 active:scale-95 transition-all text-sm">
                                Guardar Ajustes
                            </button>
                            <button type="button" onclick="restartBot()" class="w-full sm:w-auto px-8 py-3.5 bg-red-600/20 hover:bg-red-600/30 text-red-400 border border-red-500/20 rounded-2xl font-bold active:scale-95 transition-all text-sm flex items-center justify-center gap-2">
                                <i class="fa-solid fa-power-off"></i>
                                Reiniciar Bot
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- TAB: LOGS -->
            <div id="panel-logs" class="tab-panel space-y-6 hidden">
                <div class="glass-card p-6 rounded-3xl">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
                        <h2 class="text-xl font-semibold flex items-center gap-2">
                            <i class="fa-solid fa-list-ul text-teal-500"></i>
                            Registro de Actividad Reciente
                        </h2>

                        <!-- Search and filter -->
                        <div class="flex gap-2 w-full sm:w-auto">
                            <input type="text" id="logSearch" placeholder="Buscar por usuario o texto..." oninput="filterLogs()" class="rounded-xl bg-black/30 border border-white/10 px-3 py-1.5 text-xs text-white focus:border-teal-500 outline-none w-full sm:w-48">
                            <select id="logTypeFilter" onchange="filterLogs()" class="rounded-xl bg-black/30 border border-white/10 px-2 py-1.5 text-xs text-white focus:border-teal-500 outline-none">
                                <option value="all">Todos</option>
                                <option value="grupo">Grupo</option>
                                <option value="privado">Privado</option>
                            </select>
                        </div>
                    </div>

                    <div class="space-y-3 max-h-[500px] overflow-y-auto pr-2" id="logsContainer">
                        <!-- Dynamic Logs entries -->
                    </div>
                </div>
            </div>

        </section>

    </main>

    <!-- TOAST NOTIFICATIONS CONTAINER -->
    <div id="toastContainer" class="fixed bottom-6 right-6 z-50 space-y-2"></div>

    <!-- MAIN INTERACTIVITY SCRIPT -->
    <script>
        let currentTab = 'personality';

        // Fetch initial setup data
        document.addEventListener("DOMContentLoaded", () => {
            loadRules();
            loadContacts();
            loadStats();
            loadLogs();
            loadMcpServers();
        });

        // Theme toggle
        const themeBtn = document.getElementById("themeToggle");
        const themeIcon = document.getElementById("themeIcon");
        themeBtn.addEventListener("click", () => {
            const body = document.body;
            body.classList.toggle("light-theme");
            if (body.classList.contains("light-theme")) {
                themeIcon.className = "fa-solid fa-sun text-lg text-amber-500";
            } else {
                themeIcon.className = "fa-solid fa-moon text-lg text-pink-400";
            }
        });

        // Tab Switcher
        function switchTab(tabId) {
            // Hide all panels
            document.querySelectorAll(".tab-panel").forEach(panel => panel.classList.add("hidden"));
            // Deactivate all buttons
            document.querySelectorAll(".tab-btn").forEach(btn => btn.classList.remove("active"));

            // Show active panel
            document.getElementById(`panel-${tabId}`).classList.remove("hidden");
            // Set active button
            document.getElementById(`tab-${tabId}`).classList.add("active");

            currentTab = tabId;
        }

        // Show toast notifications
        function showToast(message, type = "success") {
            const toast = document.createElement("div");
            toast.className = `glass-card px-5 py-3 rounded-2xl flex items-center gap-2.5 shadow-lg border-l-4 ${type === 'success' ? 'border-l-green-500' : 'border-l-red-500'} transform translate-y-2 opacity-0 transition-all duration-300`;
            toast.innerHTML = `
                <i class="${type === 'success' ? 'fa-solid fa-circle-check text-green-400' : 'fa-solid fa-circle-exclamation text-red-400'}"></i>
                <span class="text-xs font-semibold">${message}</span>
            `;
            const container = document.getElementById("toastContainer");
            container.appendChild(toast);

            // Animation trigger
            setTimeout(() => {
                toast.classList.remove("translate-y-2", "opacity-0");
            }, 50);

            // Hide and remove
            setTimeout(() => {
                toast.classList.add("opacity-0");
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // SAVE PERSONALITY AJAX
        async function savePersonality(e) {
            e.preventDefault();
            const formData = {
                personality: document.getElementById("personality").value,
                tone: document.getElementById("tone").value,
                language: document.getElementById("language").value,
                maxLength: parseInt(document.getElementById("maxLength").value),
                creativity: parseFloat(document.getElementById("creativity").value),
                provider: document.getElementById("provider").value,
                model: document.getElementById("model").value,
                apiKey: document.getElementById("apiKey").value,
                mcpEnabled: document.getElementById("mcpEnabled").checked
            };

            try {
                const res = await fetch("/api/personality", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(formData)
                });
                if (res.ok) {
                    showToast("¡Personalidad y modelo de IA actualizados!");
                } else {
                    showToast("Error al guardar personalidad", "error");
                }
            } catch (err) {
                showToast("Error de red", "error");
            }
        }

        // SAVE BOT GENERAL CONFIG
        async function saveBotConfig(e) {
            e.preventDefault();
            const formData = {
                botName: document.getElementById("botName").value,
                prefix: document.getElementById("botPrefix").value,
                botStatus: document.getElementById("botStatus").checked,
                pairingState: document.getElementById("pairingState").checked,
                pairingNumber: document.getElementById("pairingNumber").value
            };

            try {
                const res = await fetch("/api/bot-config", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(formData)
                });
                if (res.ok) {
                    showToast("¡Ajustes del bot actualizados con éxito!");
                    const data = await res.json();
                    if (data.pairingCode) {
                        document.getElementById("pairingCodeCard").classList.remove("hidden");
                        document.getElementById("pairingCodeDisplay").innerText = data.pairingCode;
                    } else {
                        document.getElementById("pairingCodeCard").classList.add("hidden");
                    }
                } else {
                    showToast("Error al guardar ajustes", "error");
                }
            } catch (err) {
                showToast("Error de red", "error");
            }
        }

        // RESTART BOT
        async function restartBot() {
            if (!confirm("¿Estás seguro de que deseas reiniciar el proceso del Bot? Esto reconectará a la red.")) return;
            try {
                const res = await fetch("/api/restart", { method: "POST" });
                if (res.ok) {
                    showToast("Reiniciando el Bot... Por favor espera unos segundos.");
                }
            } catch (e) {
                showToast("Comando de reinicio enviado.");
            }
        }

        // RULES MANAGEMENT
        async function loadRules() {
            try {
                const res = await fetch("/api/rules");
                const rules = await res.json();
                const container = document.getElementById("rulesList");
                container.innerHTML = "";

                if (rules.length === 0) {
                    container.innerHTML = `<p class="text-xs text-gray-500 italic text-center py-4">No hay reglas definidas.</p>`;
                    return;
                }

                rules.forEach(rule => {
                    const badgeClass = rule.priority === 'alta' ? 'bg-red-500/10 text-red-400 border border-red-500/20'
                                      : rule.priority === 'media' ? 'bg-amber-500/10 text-amber-400 border border-amber-500/20'
                                      : 'bg-indigo-500/10 text-indigo-400 border border-indigo-500/20';

                    container.innerHTML += `
                        <div class="glass-card px-4 py-3 rounded-2xl flex items-center justify-between gap-3">
                            <div class="flex items-center gap-3">
                                <span class="text-xs px-2.5 py-1 rounded-full uppercase font-bold tracking-wider ${badgeClass}">${rule.priority}</span>
                                <p class="text-sm font-medium">${rule.text}</p>
                            </div>
                            <button onclick="deleteRule('${rule.id}')" class="text-red-400 hover:text-red-500 p-2 hover:bg-red-500/5 rounded-xl transition-colors">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </div>
                    `;
                });
            } catch (err) {
                console.error("Error loading rules:", err);
            }
        }

        async function addRule(e) {
            e.preventDefault();
            const text = document.getElementById("ruleText").value;
            const priority = document.getElementById("rulePriority").value;

            try {
                const res = await fetch("/api/rules", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ text, priority })
                });
                if (res.ok) {
                    showToast("Regla añadida.");
                    document.getElementById("ruleText").value = "";
                    loadRules();
                }
            } catch (err) {
                showToast("Error al añadir regla", "error");
            }
        }

        async function deleteRule(id) {
            try {
                const res = await fetch(`/api/rules/${id}`, { method: "DELETE" });
                if (res.ok) {
                    showToast("Regla eliminada.");
                    loadRules();
                }
            } catch (err) {
                showToast("Error al eliminar regla", "error");
            }
        }

        // CONTACTS MANAGEMENT
        async function loadContacts() {
            try {
                const res = await fetch("/api/contacts");
                const contacts = await res.json();
                const body = document.getElementById("contactsTableBody");
                body.innerHTML = "";

                if (contacts.length === 0) {
                    body.innerHTML = `<tr><td colspan="4" class="px-4 py-8 text-center text-gray-500 italic">No hay contactos agregados.</td></tr>`;
                    return;
                }

                contacts.forEach(c => {
                    const statusClass = c.status === 'respondido' ? 'bg-green-500/10 text-green-400 border border-green-500/20'
                                      : c.status === 'enviado' ? 'bg-blue-500/10 text-blue-400 border border-blue-500/20'
                                      : 'bg-yellow-500/10 text-yellow-400 border border-yellow-500/20';

                    body.innerHTML += `
                        <tr class="hover:bg-white/5 transition-colors">
                            <td class="px-4 py-3 font-semibold text-gray-300">${c.number}</td>
                            <td class="px-4 py-3 text-gray-400">${c.message || '<em class="text-gray-600">Mensaje General</em>'}</td>
                            <td class="px-4 py-3">
                                <span class="px-2.5 py-0.5 text-xs rounded-full font-bold uppercase tracking-wider ${statusClass}">${c.status}</span>
                            </td>
                            <td class="px-4 py-3 text-right">
                                <button onclick="deleteContact('${c.id}')" class="text-red-400 hover:text-red-500 p-2 hover:bg-red-500/5 rounded-xl transition-colors">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                });
            } catch (err) {
                console.error("Error loading contacts:", err);
            }
        }

        async function addContact(e) {
            e.preventDefault();
            const number = document.getElementById("contactNumber").value;
            const message = document.getElementById("contactMessage").value;

            try {
                const res = await fetch("/api/contacts", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ number, message })
                });
                if (res.ok) {
                    showToast("Contacto de campaña añadido.");
                    document.getElementById("contactNumber").value = "";
                    document.getElementById("contactMessage").value = "";
                    loadContacts();
                }
            } catch (err) {
                showToast("Error de red", "error");
            }
        }

        async function deleteContact(id) {
            try {
                const res = await fetch(`/api/contacts/${id}`, { method: "DELETE" });
                if (res.ok) {
                    showToast("Contacto eliminado de la lista.");
                    loadContacts();
                }
            } catch (err) {
                showToast("Error al eliminar contacto", "error");
            }
        }

        async function triggerProactiveMessages() {
            try {
                const res = await fetch("/api/contacts/send", { method: "POST" });
                if (res.ok) {
                    showToast("Enviando mensajes de prospección en segundo plano...");
                    setTimeout(loadContacts, 2000);
                } else {
                    showToast("Fallo al iniciar campaña de prospección", "error");
                }
            } catch (e) {
                showToast("Fallo al iniciar envío", "error");
            }
        }

        // STATS AND MONITORS
        async function loadStats() {
            try {
                const res = await fetch("/api/stats");
                const data = await res.json();

                document.getElementById("statTotalUsers").innerText = data.totalUsers;
                document.getElementById("statActiveUsers").innerText = data.activeUsers;
                document.getElementById("statMsgProcessed").innerText = data.messagesProcessed;
                document.getElementById("statResponseRate").innerText = data.responseRate;

                // Build a gorgeous CSS SVG Bar Graph for 7 days
                const activityGraph = document.getElementById("activityGraph");
                activityGraph.innerHTML = "";
                const days = data.graphData || [0,0,0,0,0,0,0];
                const maxVal = Math.max(...days, 5);

                const weekDays = ["Lun", "Mar", "Mié", "Jue", "Vie", "Sáb", "Dom"];
                days.forEach((val, idx) => {
                    const heightPercent = Math.round((val / maxVal) * 100);
                    activityGraph.innerHTML += `
                        <div class="flex-1 flex flex-col items-center h-full justify-end">
                            <div class="w-full sm:w-10 bg-gradient-to-t from-indigo-500 to-pink-500 rounded-t-xl hover:opacity-95 transition-all flex items-center justify-center text-[10px] font-bold text-white shadow-lg shadow-pink-500/10" style="height: ${heightPercent}%">
                                ${val > 0 ? val : ''}
                            </div>
                            <span class="text-[10px] text-gray-500 font-semibold mt-2">${weekDays[idx]}</span>
                        </div>
                    `;
                });
            } catch (e) {
                console.error("Error loading stats:", e);
            }
        }

        // REAL-TIME LOGS
        let rawLogs = [];
        async function loadLogs() {
            try {
                const res = await fetch("/api/logs");
                rawLogs = await res.json();
                filterLogs();
            } catch (e) {
                console.error(e);
            }
        }

        function filterLogs() {
            const query = document.getElementById("logSearch").value.toLowerCase();
            const filterType = document.getElementById("logTypeFilter").value;
            const container = document.getElementById("logsContainer");
            container.innerHTML = "";

            const filtered = rawLogs.filter(log => {
                const matchesSearch = log.user.toLowerCase().includes(query) || log.message.toLowerCase().includes(query) || log.response.toLowerCase().includes(query);
                const matchesType = filterType === 'all' || log.type === filterType;
                return matchesSearch && matchesType;
            });

            if (filtered.length === 0) {
                container.innerHTML = `<p class="text-xs text-gray-500 italic text-center py-8">No hay logs coincidentes.</p>`;
                return;
            }

            filtered.forEach(log => {
                const formattedTime = new Date(log.timestamp).toLocaleTimeString();
                const typeBadge = log.type === 'grupo' ? 'bg-cyan-500/10 text-cyan-400 border border-cyan-500/20' : 'bg-pink-500/10 text-pink-400 border border-pink-500/20';

                container.innerHTML += `
                    <div class="glass-card p-4 rounded-2xl space-y-2 text-xs">
                        <div class="flex justify-between items-center border-b border-white/5 pb-1.5">
                            <div class="flex items-center gap-2">
                                <span class="font-bold text-pink-400">@${log.user}</span>
                                <span class="px-2 py-0.5 rounded text-[9px] uppercase tracking-wider font-extrabold ${typeBadge}">${log.type}</span>
                            </div>
                            <span class="text-gray-500 font-semibold">${formattedTime}</span>
                        </div>
                        <div class="space-y-1">
                            <p class="text-gray-300"><strong class="text-gray-500">M:</strong> ${log.message}</p>
                            <p class="text-pink-100 font-medium"><strong class="text-purple-400">R:</strong> ${log.response}</p>
                        </div>
                    </div>
                `;
            });
        }

        // MCP SERVERS MANAGEMENT
        async function loadMcpServers() {
            try {
                const res = await fetch("/api/mcp-servers");
                const servers = await res.json();
                const container = document.getElementById("mcpServersList");
                container.innerHTML = "";

                if (servers.length === 0) {
                    container.innerHTML = `<p class="text-xs text-gray-500 italic py-2">No hay servidores MCP vinculados.</p>`;
                    return;
                }

                servers.forEach((srv, idx) => {
                    container.innerHTML += `
                        <div class="flex items-center justify-between bg-white/5 border border-white/5 p-3 rounded-xl text-xs">
                            <div class="flex items-center gap-2">
                                <span class="w-2 h-2 rounded-full bg-cyan-400 pulse-dot inline-block"></span>
                                <strong class="text-gray-300">${srv.name}</strong>
                                <span class="text-gray-500 font-mono text-[10px]">(${srv.url})</span>
                            </div>
                            <button type="button" onclick="deleteMcpServer(${idx})" class="text-red-400 hover:text-red-500 p-1.5 hover:bg-red-500/5 rounded-lg transition-colors">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </div>
                    `;
                });
            } catch (err) {
                console.error(err);
            }
        }

        async function addMcpServer() {
            const name = document.getElementById("newMcpName").value;
            const url = document.getElementById("newMcpUrl").value;

            if (!name || !url) {
                showToast("Por favor define el nombre y la URL del servidor MCP", "error");
                return;
            }

            try {
                const res = await fetch("/api/mcp-servers", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ name, url })
                });
                if (res.ok) {
                    showToast("Servidor MCP añadido con éxito.");
                    document.getElementById("newMcpName").value = "";
                    document.getElementById("newMcpUrl").value = "";
                    loadMcpServers();
                }
            } catch (e) {
                showToast("Fallo al conectar MCP", "error");
            }
        }

        async function deleteMcpServer(index) {
            try {
                const res = await fetch(`/api/mcp-servers/${index}`, { method: "DELETE" });
                if (res.ok) {
                    showToast("Servidor MCP eliminado.");
                    loadMcpServers();
                }
            } catch (err) {
                showToast("Fallo al eliminar MCP", "error");
            }
        }

        // Helper copy pairing code
        function copyPairingCode() {
            const code = document.getElementById("pairingCodeDisplay").innerText;
            navigator.clipboard.writeText(code);
            showToast("Código de Vinculación copiado!");
        }

        // Switch custom models on provider change
        function updateProviderModels() {
            const provider = document.getElementById("provider").value;
            const modelInput = document.getElementById("model");
            if (provider === 'gemini') {
                modelInput.value = 'gemini-2.0-flash';
            } else if (provider === 'openrouter') {
                modelInput.value = 'google/gemini-2.0-flash';
            } else if (provider === 'grok') {
                modelInput.value = 'grok-2-1212';
            }
        }

        // Toggle MCP section visibility
        document.getElementById("mcpEnabled").addEventListener("change", (e) => {
            const section = document.getElementById("mcpServersSection");
            if (e.target.checked) {
                section.classList.remove("hidden");
            } else {
                section.classList.add("hidden");
            }
        });
    </script>
</body>
</html>
