<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YOSHIDA - Panel de Administración</title>
    <!-- Tailwind CSS Foundation -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=SF+Pro+Display:wght@300;400;500;600;700&display=swap');

        body {
            font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: linear-gradient(135deg, #f5f3ff, #ede9fe, #fae8ff);
            background-attachment: fixed;
            min-height: 100vh;
            color: #1e1b4b;
            transition: all 0.5s ease;
        }

        /* Apple iOS Glassmorphism Effects (White Base with Purple Glow) */
        .glass-card {
            background: rgba(255, 255, 255, 0.45);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 1px solid rgba(124, 58, 237, 0.15);
            box-shadow: 0 10px 40px 0 rgba(124, 58, 237, 0.05);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .glass-card:hover {
            border-color: rgba(124, 58, 237, 0.25);
            box-shadow: 0 16px 50px 0 rgba(124, 58, 237, 0.1);
            transform: translateY(-2px);
        }

        /* iOS active navigation indicator */
        .tab-btn {
            position: relative;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .tab-btn.active {
            color: #7c3aed;
            background: rgba(124, 58, 237, 0.08);
            border-color: rgba(124, 58, 237, 0.2);
            text-shadow: 0 0 15px rgba(124, 58, 237, 0.15);
        }

        /* Apple iOS Switches */
        .ios-switch {
            position: relative;
            display: inline-block;
            width: 48px;
            height: 28px;
        }
        .ios-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }
        .ios-slider {
            position: absolute;
            cursor: pointer;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: rgba(0, 0, 0, 0.06);
            transition: .4s;
            border-radius: 34px;
            border: 1px solid rgba(0, 0, 0, 0.03);
        }
        .ios-slider:before {
            position: absolute;
            content: "";
            height: 22px;
            width: 22px;
            left: 2px;
            bottom: 2px;
            background-color: white;
            transition: .3s cubic-bezier(0.16, 1, 0.3, 1);
            border-radius: 50%;
            box-shadow: 0 2px 6px rgba(0,0,0,0.15);
        }
        input:checked + .ios-slider {
            background: linear-gradient(135deg, #7c3aed, #4f46e5);
        }
        input:checked + .ios-slider:before {
            transform: translateX(20px);
        }

        /* Real-time indicator pulse animation */
        @keyframes pulse-glow {
            0%, 100% { opacity: 0.6; transform: scale(1); }
            50% { opacity: 1; transform: scale(1.15); }
        }
        .pulse-dot {
            animation: pulse-glow 2s infinite ease-in-out;
        }

        /* Custom Scrollbar for sleek UI */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(0,0,0,0.03);
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(124, 58, 237, 0.12);
            border-radius: 9999px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(124, 58, 237, 0.25);
        }
    </style>
</head>
<body class="antialiased pb-20">

    <!-- TOP HEADER -->
    <header class="w-full max-w-7xl mx-auto px-6 pt-6 pb-2 flex justify-between items-center">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-gradient-to-tr from-purple-500 to-indigo-600 flex items-center justify-center shadow-xl shadow-purple-500/20">
                <i class="fa-solid fa-robot text-xl text-white"></i>
            </div>
            <div>
                <h1 class="font-bold text-2xl tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-purple-600 via-indigo-600 to-indigo-400">
                    <%= botName %> Admin
                </h1>
                <p class="text-xs text-indigo-950/50 flex items-center gap-1.5 font-semibold">
                    <span id="connIndicator" class="w-2.5 h-2.5 rounded-full bg-green-500 pulse-dot inline-block"></span>
                    <span id="connText">Verificando conexión...</span>
                </p>
            </div>
        </div>

        <div class="flex items-center gap-3">
            <div class="px-4 py-2 bg-purple-500/10 text-purple-600 border border-purple-500/15 text-xs font-bold rounded-xl flex items-center gap-1.5 shadow-sm">
                <i class="fa-solid fa-sparkles"></i> iOS Glassmorphic
            </div>
        </div>
    </header>

    <!-- MAIN BODY GRID Layout -->
    <main class="w-full max-w-7xl mx-auto px-6 mt-6 grid grid-cols-1 lg:grid-cols-4 gap-6">

        <!-- NAVIGATION COL (Left Side) -->
        <nav class="lg:col-span-1 flex lg:flex-col overflow-x-auto lg:overflow-x-visible pb-2 lg:pb-0 gap-2 scrollbar-none">
            <button onclick="switchTab('personality')" id="tab-personality" class="tab-btn active flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-semibold w-full min-w-[150px] lg:min-w-0">
                <i class="fa-solid fa-brain text-purple-600 text-lg"></i>
                <span>Personalidad / AI</span>
            </button>
            <button onclick="switchTab('autoresponses')" id="tab-autoresponses" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-semibold w-full min-w-[150px] lg:min-w-0">
                <i class="fa-solid fa-reply text-purple-500 text-lg"></i>
                <span>Respuestas</span>
            </button>
            <button onclick="switchTab('rules')" id="tab-rules" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-semibold w-full min-w-[150px] lg:min-w-0">
                <i class="fa-solid fa-scroll text-violet-500 text-lg"></i>
                <span>Reglas</span>
            </button>
            <button onclick="switchTab('users')" id="tab-users" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-semibold w-full min-w-[150px] lg:min-w-0">
                <i class="fa-solid fa-users text-indigo-500 text-lg"></i>
                <span>Usuarios</span>
            </button>
            <button onclick="switchTab('schedules')" id="tab-schedules" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-semibold w-full min-w-[150px] lg:min-w-0">
                <i class="fa-solid fa-calendar-days text-pink-500 text-lg"></i>
                <span>Programación</span>
            </button>
            <button onclick="switchTab('statuses')" id="tab-statuses" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-semibold w-full min-w-[150px] lg:min-w-0">
                <i class="fa-solid fa-image text-rose-500 text-lg"></i>
                <span>Estados WA</span>
            </button>
            <button onclick="switchTab('polls')" id="tab-polls" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-semibold w-full min-w-[150px] lg:min-w-0">
                <i class="fa-solid fa-square-poll-vertical text-emerald-500 text-lg"></i>
                <span>Encuestas</span>
            </button>
            <button onclick="switchTab('agents')" id="tab-agents" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-semibold w-full min-w-[150px] lg:min-w-0">
                <i class="fa-solid fa-user-gear text-teal-500 text-lg"></i>
                <span>10 Agentes</span>
            </button>
            <button onclick="switchTab('stats')" id="tab-stats" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-semibold w-full min-w-[150px] lg:min-w-0">
                <i class="fa-solid fa-chart-line text-cyan-500 text-lg"></i>
                <span>Telemetría</span>
            </button>
            <button onclick="switchTab('logs')" id="tab-logs" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-semibold w-full min-w-[150px] lg:min-w-0">
                <i class="fa-solid fa-list-ul text-blue-500 text-lg"></i>
                <span>Logs de Chat</span>
            </button>
            <button onclick="switchTab('config')" id="tab-config" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-semibold w-full min-w-[150px] lg:min-w-0">
                <i class="fa-solid fa-gears text-amber-500 text-lg"></i>
                <span>Ajustes Generales</span>
            </button>
        </nav>

        <!-- CONTENT PANEL (Right Side) -->
        <section class="lg:col-span-3 space-y-6">

            <!-- TAB: PERSONALIDAD -->
            <div id="panel-personality" class="tab-panel space-y-6">
                <div class="glass-card p-7 rounded-[30px]">
                    <h2 class="text-xl font-bold mb-4 flex items-center gap-2 text-purple-950">
                        <i class="fa-solid fa-brain text-purple-600"></i>
                        Personalidad de la IA
                    </h2>
                    <form id="personalityForm" class="space-y-4" onsubmit="savePersonality(event)">
                        <div>
                            <label class="block text-xs font-semibold text-indigo-950/60 uppercase tracking-wider mb-2">Instrucción Principal (Público)</label>
                            <textarea id="personality" name="personality" rows="3" class="w-full rounded-2xl bg-white/70 border border-purple-200/50 px-4 py-3 text-indigo-950 focus:border-purple-600 outline-none resize-none transition-all shadow-inner"><%= aiConfig.personality %></textarea>
                        </div>

                        <div>
                            <label class="block text-xs font-semibold text-indigo-950/60 uppercase tracking-wider mb-2">Personalidad Especial para el Administrador (Tú)</label>
                            <textarea id="adminPersonality" name="adminPersonality" rows="3" placeholder="Define cómo hablará el bot contigo (ej: Eres un asistente extremadamente servicial, respetuoso y formal con el administrador...)" class="w-full rounded-2xl bg-white/70 border border-purple-200/50 px-4 py-3 text-indigo-950 focus:border-purple-600 outline-none resize-none transition-all shadow-inner"><%= aiConfig.adminPersonality || "" %></textarea>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-semibold text-indigo-950/60 uppercase tracking-wider mb-2">Tono Conversacional</label>
                                <input type="text" id="tone" name="tone" value="<%= aiConfig.tone %>" class="w-full rounded-2xl bg-white/70 border border-purple-200/50 px-4 py-3 text-indigo-950 focus:border-purple-600 outline-none shadow-inner">
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-indigo-950/60 uppercase tracking-wider mb-2">Tono para el Administrador</label>
                                <input type="text" id="adminTone" name="adminTone" value="<%= aiConfig.adminTone || "" %>" placeholder="ej: respetuoso" class="w-full rounded-2xl bg-white/70 border border-purple-200/50 px-4 py-3 text-indigo-950 focus:border-purple-600 outline-none shadow-inner">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-semibold text-indigo-950/60 uppercase tracking-wider mb-2">Tokens Máximos</label>
                                <input type="number" id="maxLength" name="maxLength" value="<%= aiConfig.maxLength %>" class="w-full rounded-2xl bg-white/70 border border-purple-200/50 px-4 py-3 text-indigo-950 shadow-inner">
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-indigo-950/60 uppercase tracking-wider mb-2">Temperatura (Creatividad)</label>
                                <input type="number" step="0.1" id="creativity" name="creativity" value="<%= aiConfig.creativity %>" class="w-full rounded-2xl bg-white/70 border border-purple-200/50 px-4 py-3 text-indigo-950 shadow-inner">
                            </div>
                        </div>

                        <div class="border-t border-purple-200/50 pt-5 space-y-4">
                            <h3 class="text-sm font-bold tracking-wider text-purple-600 uppercase">Configuración de Modelo</h3>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-xs font-semibold text-indigo-950/60 uppercase tracking-wider mb-2">Proveedor</label>
                                    <select id="provider" name="provider" onchange="updateProviderModels()" class="w-full rounded-2xl bg-white/70 border border-purple-200/50 px-4 py-3 text-indigo-950 outline-none appearance-none shadow-inner">
                                        <option value="gemini" <%= aiConfig.provider === 'gemini' ? 'selected' : '' %>>Google Gemini</option>
                                        <option value="openrouter" <%= aiConfig.provider === 'openrouter' ? 'selected' : '' %>>OpenRouter</option>
                                        <option value="grok" <%= aiConfig.provider === 'grok' ? 'selected' : '' %>>xAI Grok</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-xs font-semibold text-indigo-950/60 uppercase tracking-wider mb-2">Modelo</label>
                                    <input type="text" id="model" name="model" value="<%= aiConfig.model %>" class="w-full rounded-2xl bg-white/70 border border-purple-200/50 px-4 py-3 text-indigo-950 outline-none shadow-inner">
                                </div>
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-indigo-950/60 uppercase tracking-wider mb-2">API Key (Opcional)</label>
                                <input type="password" id="apiKey" name="apiKey" value="<%= aiConfig.apiKey %>" placeholder="Dejar vacío para usar variable de entorno" class="w-full rounded-2xl bg-white/70 border border-purple-200/50 px-4 py-3 text-indigo-950 shadow-inner">
                            </div>
                        </div>

                        <div class="border-t border-purple-200/50 pt-5">
                            <div class="flex items-center justify-between">
                                <div>
                                    <h3 class="text-sm font-bold text-indigo-950">Servidores MCP (Model Context Protocol)</h3>
                                    <p class="text-xs text-indigo-950/50">Conectar herramientas y recursos externos a la IA.</p>
                                </div>
                                <label class="ios-switch">
                                    <input type="checkbox" id="mcpEnabled" name="mcpEnabled" <%= aiConfig.mcpEnabled ? 'checked' : '' %>>
                                    <span class="ios-slider"></span>
                                </label>
                            </div>

                            <div id="mcpServersSection" class="mt-4 space-y-3 <%= aiConfig.mcpEnabled ? '' : 'hidden' %>">
                                <div id="mcpServersList" class="space-y-2"></div>
                                <div class="flex gap-2">
                                    <input type="text" id="newMcpName" placeholder="Nombre (ej: DB)" class="w-1/3 rounded-xl bg-white/70 border border-purple-200/50 px-3 py-2 text-sm shadow-inner">
                                    <input type="text" id="newMcpUrl" placeholder="http://localhost:5001" class="w-2/3 rounded-xl bg-white/70 border border-purple-200/50 px-3 py-2 text-sm shadow-inner">
                                    <button type="button" onclick="addMcpServer()" class="px-4 py-2 bg-gradient-to-tr from-purple-500 to-indigo-600 text-white rounded-xl text-sm font-bold shadow-md shadow-purple-500/10">
                                        <i class="fa-solid fa-plus"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="pt-4 flex justify-end">
                            <button type="submit" class="w-full sm:w-auto px-8 py-3.5 bg-gradient-to-r from-purple-600 via-indigo-600 to-indigo-500 text-white rounded-2xl font-bold tracking-wide shadow-lg shadow-purple-500/10">
                                Guardar Cambios
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Live Connection & QR Status Card -->
                <div class="glass-card p-7 rounded-[30px] mt-6">
                    <h2 class="text-xl font-bold mb-4 flex items-center gap-2 text-purple-950">
                        <i class="fa-solid fa-qrcode text-purple-600"></i>
                        Vincular WhatsApp
                    </h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-center">
                        <div class="space-y-4">
                            <div>
                                <p class="text-xs font-semibold text-indigo-950/60 uppercase tracking-wider mb-1">Número Vinculado</p>
                                <p id="connectedNumberDisplay" class="text-lg font-bold text-indigo-950">No vinculado</p>
                            </div>
                            <div>
                                <p class="text-xs font-semibold text-indigo-950/60 uppercase tracking-wider mb-1">Tiempo de Actividad (Uptime)</p>
                                <p id="uptimeDisplay" class="text-lg font-bold text-indigo-950">0s</p>
                            </div>
                            <button type="button" onclick="reconnectBot()" class="w-full sm:w-auto px-6 py-3 bg-gradient-to-r from-purple-600 to-indigo-600 text-white font-bold rounded-2xl text-sm transition-all flex items-center justify-center gap-2 shadow-lg shadow-purple-500/10">
                                <i class="fa-solid fa-rotate"></i> Forzar Reconexión / QR
                            </button>
                        </div>
                        <div class="flex flex-col items-center justify-center p-4 rounded-2xl bg-white/40 border border-purple-200/50 min-h-[220px]">
                            <div id="qrContainer" class="w-48 h-48 flex items-center justify-center text-center">
                                <p class="text-xs text-indigo-950/40 italic">Cargando código QR...</p>
                            </div>
                            <div id="qrStatusText" class="text-xs font-bold mt-2 text-indigo-950/50 flex items-center gap-1.5">
                                <span id="qrStatusDot" class="w-2 h-2 rounded-full bg-yellow-500 pulse-dot inline-block"></span> <span id="qrStatusLabel">Esperando QR...</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TAB: AUTO-RESPUESTAS -->
            <div id="panel-autoresponses" class="tab-panel space-y-6 hidden">
                <div class="glass-card p-7 rounded-[30px]">
                    <h2 class="text-xl font-bold mb-4 flex items-center gap-2 text-purple-950">
                        <i class="fa-solid fa-reply text-purple-600"></i>
                        Respuestas Automáticas
                    </h2>

                    <!-- Config welcome and absence -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                        <div class="space-y-3">
                            <div class="flex items-center justify-between">
                                <label class="text-sm font-semibold text-purple-600">Modo Ausencia</label>
                                <label class="ios-switch">
                                    <input type="checkbox" id="absenceMode" onchange="saveAutoResponseSettings()">
                                    <span class="ios-slider"></span>
                                </label>
                            </div>
                            <textarea id="absenceMessage" rows="2" class="w-full rounded-xl bg-white/70 border border-purple-200/50 px-3 py-2 text-xs text-indigo-950 shadow-inner" placeholder="Mensaje de ausencia..."></textarea>
                        </div>
                        <div class="space-y-3">
                            <label class="text-sm font-semibold text-purple-600 block">Mensaje de Bienvenida Grupal (Por Defecto)</label>
                            <p class="text-[10px] text-indigo-950/50">Se envía a nuevos participantes de grupos si está activado.</p>
                            <textarea readonly class="w-full rounded-xl bg-black/5 border border-purple-200/10 px-3 py-2 text-xs text-indigo-950/60 shadow-inner">Se administra vía comandos de WhatsApp y se envía de forma automática.</textarea>
                        </div>
                    </div>

                    <!-- Keywords List -->
                    <div class="border-t border-purple-200/50 pt-5 space-y-4">
                        <h3 class="text-sm font-bold text-indigo-950">Respuestas por Palabra Clave</h3>
                        <div id="keywordsList" class="space-y-2"></div>

                        <!-- Add Rule -->
                        <form onsubmit="addKeywordRule(event)" class="grid grid-cols-1 sm:grid-cols-3 gap-2 items-end pt-2">
                            <div>
                                <label class="block text-xs text-indigo-950/60 mb-1">Palabra Clave</label>
                                <input type="text" id="newKeyword" required placeholder="ej: soporte" class="w-full rounded-xl bg-white/70 border border-purple-200/50 px-3 py-2.5 text-xs text-indigo-950 shadow-inner">
                            </div>
                            <div>
                                <label class="block text-xs text-indigo-950/60 mb-1">Respuesta del Bot</label>
                                <input type="text" id="newResponse" required placeholder="Hola, te ayudamos..." class="w-full rounded-xl bg-white/70 border border-purple-200/50 px-3 py-2.5 text-xs text-indigo-950 shadow-inner">
                            </div>
                            <button type="submit" class="w-full py-2.5 bg-gradient-to-r from-purple-500 to-indigo-600 text-white rounded-xl font-bold text-xs shadow-md shadow-purple-500/10">
                                <i class="fa-solid fa-plus"></i> Guardar Regla
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- TAB: REGLAS -->
            <div id="panel-rules" class="tab-panel space-y-6 hidden">
                <div class="glass-card p-7 rounded-[30px]">
                    <h2 class="text-xl font-bold mb-4 flex items-center gap-2 text-purple-950">
                        <i class="fa-solid fa-scroll text-purple-600"></i>
                        Reglas de la IA (Programables)
                    </h2>
                    <div id="rulesList" class="space-y-3 mb-6"></div>

                    <div class="border-t border-purple-200/50 pt-5">
                        <h3 class="text-sm font-bold text-indigo-950 mb-3">Añadir Nueva Regla</h3>
                        <form id="ruleForm" class="grid grid-cols-1 sm:grid-cols-3 gap-3 items-end" onsubmit="addRule(event)">
                            <div class="sm:col-span-2">
                                <label class="block text-xs text-indigo-950/60 mb-1">Regla (Soporta comportamiento lógico si se desea)</label>
                                <input type="text" id="ruleText" required placeholder="No envíes más de 100 mensajes por hora / El bot no puede hablar de política..." class="w-full rounded-2xl bg-white/70 border border-purple-200/50 px-4 py-3 text-sm text-indigo-950 shadow-inner">
                            </div>
                            <div class="flex gap-2">
                                <div class="w-full">
                                    <label class="block text-xs text-indigo-950/60 mb-1">Prioridad</label>
                                    <select id="rulePriority" class="w-full rounded-2xl bg-white/70 border border-purple-200/50 px-3 py-3 text-sm text-indigo-950 outline-none shadow-inner">
                                        <option value="alta">Alta</option>
                                        <option value="media">Media</option>
                                        <option value="baja">Baja</option>
                                    </select>
                                </div>
                                <button type="submit" class="px-5 py-3 bg-gradient-to-tr from-purple-500 to-indigo-600 text-white rounded-2xl font-bold shadow-md shadow-purple-500/10">
                                    <i class="fa-solid fa-plus"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- TAB: USUARIOS -->
            <div id="panel-users" class="tab-panel space-y-6 hidden">
                <div class="glass-card p-7 rounded-[30px]">
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-4">
                        <h2 class="text-xl font-bold flex items-center gap-2 text-purple-950">
                            <i class="fa-solid fa-users text-purple-600"></i>
                            Gestión de Usuarios Registrados
                        </h2>
