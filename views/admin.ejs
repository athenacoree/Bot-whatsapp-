    <!-- TOAST NOTIFICATION STACK -->
    <div id="toastContainer" class="fixed bottom-6 right-6 z-50 space-y-2"></div>

    <script>
        let currentTab = 'personality';
        let rawLogs = [];
        let rawUsers = [];

        const AGENTS_LIST = [
            { id: "investigador", name: "Investigador", emoji: "🔍" },
            { id: "programador", name: "Programador", emoji: "💻" },
            { id: "disenador", name: "Diseñador", emoji: "🎨" },
            { id: "analista", name: "Analista", emoji: "📊" },
            { id: "creativo", name: "Creativo", emoji: "💡" },
            { id: "traductor", name: "Traductor", emoji: "🌐" },
            { id: "marketing", name: "Marketing", emoji: "📈" },
            { id: "soporte", name: "Soporte", emoji: "🛠️" },
            { id: "estratega", name: "Estratega", emoji: "♟️" },
            { id: "monitor", name: "Monitor", emoji: "🖥️" }
        ];

        // ON LOAD INITIALIZATION
        document.addEventListener("DOMContentLoaded", () => {
            loadRules();
            loadMcpServers();
            loadAutoResponseSettings();
            renderAgentsGrid();

            // Poll for telemetry, users and QR instantly on startup
            fetchTelemetryData();
            loadUsers();
            loadSchedules();
            loadPolls();
            loadStatuses();
            pollQRStatus();

            // Set up AJAX polling timers
            setInterval(fetchTelemetryData, 3000);
            setInterval(loadUsers, 4000);
            setInterval(pollQRStatus, 4000);
        });

        // TABS SELECTOR
        function switchTab(tabId) {
            document.querySelectorAll(".tab-panel").forEach(panel => panel.classList.add("hidden"));
            document.querySelectorAll(".tab-btn").forEach(btn => btn.classList.remove("active"));

            document.getElementById(`panel-${tabId}`).classList.remove("hidden");
            document.getElementById(`tab-${tabId}`).classList.add("active");
            currentTab = tabId;

            if (tabId === 'stats') fetchTelemetryData();
            if (tabId === 'logs') fetchTelemetryData();
            if (tabId === 'users') loadUsers();
            if (tabId === 'schedules') loadSchedules();
            if (tabId === 'statuses') loadStatuses();
            if (tabId === 'polls') loadPolls();
        }

        // SHOW POPUP TOAST
        function showToast(message, type = "success") {
            const toast = document.createElement("div");
            toast.className = `glass-card px-5 py-3.5 rounded-2xl flex items-center gap-2.5 shadow-lg border-l-4 ${type === 'success' ? 'border-l-purple-500' : 'border-l-red-500'} transform translate-y-2 opacity-0 transition-all duration-300`;
            toast.innerHTML = `
                <i class="${type === 'success' ? 'fa-solid fa-circle-check text-purple-600' : 'fa-solid fa-circle-exclamation text-red-500'}"></i>
                <span class="text-xs font-bold text-indigo-950">${message}</span>
            `;
            const container = document.getElementById("toastContainer");
            container.appendChild(toast);

            setTimeout(() => { toast.classList.remove("translate-y-2", "opacity-0"); }, 50);
            setTimeout(() => {
                toast.classList.add("opacity-0");
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // SAVE PERSONALITY IA
        async function savePersonality(e) {
