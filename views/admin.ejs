<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YOSHIDA - Panel de Control</title>
    <!-- Tailwind CSS Foundation -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=SF+Pro+Display:wght@300;400;500;600;700&display=swap');

        body {
            font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: linear-gradient(135deg, #070b12, #0d1222, #1a163a, #2a0b38);
            background-attachment: fixed;
            min-height: 100vh;
            color: #f8fafc;
            transition: all 0.5s ease;
        }

        /* Apple iOS Glassmorphism Effects */
        .glass-card {
            background: rgba(255, 255, 255, 0.025);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 12px 40px 0 rgba(0, 0, 0, 0.4);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .glass-card:hover {
            border-color: rgba(255, 255, 255, 0.15);
            box-shadow: 0 16px 50px 0 rgba(0, 0, 0, 0.5);
            transform: translateY(-2px);
        }

        /* iOS active navigation indicator */
        .tab-btn {
            position: relative;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .tab-btn.active {
            color: #ec4899;
            background: rgba(236, 72, 153, 0.08);
            border-color: rgba(236, 72, 153, 0.2);
            text-shadow: 0 0 15px rgba(236, 72, 153, 0.3);
        }

        /* Apple iOS Switches */
        .ios-switch {
            position: relative;
            display: inline-block;
            width: 48px;
            height: 28px;
        }
        .ios-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }
        .ios-slider {
            position: absolute;
            cursor: pointer;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: rgba(255, 255, 255, 0.1);
            transition: .4s;
            border-radius: 34px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .ios-slider:before {
            position: absolute;
            content: "";
            height: 22px;
            width: 22px;
            left: 2px;
            bottom: 2px;
            background-color: white;
            transition: .3s cubic-bezier(0.16, 1, 0.3, 1);
            border-radius: 50%;
            box-shadow: 0 2px 6px rgba(0,0,0,0.4);
        }
        input:checked + .ios-slider {
            background: linear-gradient(135deg, #ec4899, #8b5cf6);
        }
        input:checked + .ios-slider:before {
            transform: translateX(20px);
        }

        /* Real-time indicator pulse animation */
        @keyframes pulse-glow {
            0%, 100% { opacity: 0.6; transform: scale(1); }
            50% { opacity: 1; transform: scale(1.15); }
        }
        .pulse-dot {
            animation: pulse-glow 2s infinite ease-in-out;
        }

        /* Custom Scrollbar for sleek UI */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(0,0,0,0.15);
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.08);
            border-radius: 9999px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.15);
        }
    </style>
</head>
<body class="antialiased pb-20">

    <!-- TOP HEADER -->
    <header class="w-full max-w-7xl mx-auto px-6 pt-6 pb-2 flex justify-between items-center">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-gradient-to-tr from-pink-500 via-purple-600 to-indigo-600 flex items-center justify-center shadow-xl shadow-pink-500/20">
                <i class="fa-solid fa-robot text-xl text-white"></i>
            </div>
            <div>
                <h1 class="font-bold text-2xl tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-pink-500 via-purple-400 to-indigo-400">
                    YOSHIDA Bot
                </h1>
                <p class="text-xs text-gray-400 flex items-center gap-1.5 font-medium">
                    <span id="connIndicator" class="w-2.5 h-2.5 rounded-full bg-green-500 pulse-dot inline-block"></span>
                    <span id="connText">Verificando conexión...</span>
                </p>
            </div>
        </div>

        <div class="flex items-center gap-3">
            <a href="/logout" class="px-4 py-2 bg-red-600/10 hover:bg-red-600/20 text-red-400 border border-red-500/15 text-xs font-semibold rounded-xl transition-all flex items-center gap-1.5">
                <i class="fa-solid fa-sign-out-alt"></i> Salir
            </a>
        </div>
    </header>

    <!-- MAIN BODY GRID Layout -->
    <main class="w-full max-w-7xl mx-auto px-6 mt-6 grid grid-cols-1 lg:grid-cols-4 gap-6">

        <!-- NAVIGATION COL (Left Side) -->
        <nav class="lg:col-span-1 flex lg:flex-col overflow-x-auto lg:overflow-x-visible pb-2 lg:pb-0 gap-2 scrollbar-none">
            <button onclick="switchTab('personality')" id="tab-personality" class="tab-btn active flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-semibold w-full min-w-[150px] lg:min-w-0">
                <i class="fa-solid fa-brain text-pink-500 text-lg"></i>
                <span>Personalidad</span>
            </button>
            <button onclick="switchTab('autoresponses')" id="tab-autoresponses" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-semibold w-full min-w-[150px] lg:min-w-0">
                <i class="fa-solid fa-reply text-purple-500 text-lg"></i>
                <span>Auto-Respuestas</span>
            </button>
            <button onclick="switchTab('rules')" id="tab-rules" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-semibold w-full min-w-[150px] lg:min-w-0">
                <i class="fa-solid fa-scroll text-violet-500 text-lg"></i>
                <span>Reglas de IA</span>
            </button>
            <button onclick="switchTab('users')" id="tab-users" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-semibold w-full min-w-[150px] lg:min-w-0">
                <i class="fa-solid fa-users text-indigo-500 text-lg"></i>
                <span>Gestionar Usuarios</span>
            </button>
            <button onclick="switchTab('contacts')" id="tab-contacts" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-semibold w-full min-w-[150px] lg:min-w-0">
                <i class="fa-solid fa-paper-plane text-cyan-500 text-lg"></i>
                <span>Campañas</span>
            </button>
            <button onclick="switchTab('stats')" id="tab-stats" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-semibold w-full min-w-[150px] lg:min-w-0">
                <i class="fa-solid fa-chart-line text-teal-500 text-lg"></i>
                <span>Telemetría</span>
            </button>
            <button onclick="switchTab('logs')" id="tab-logs" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-semibold w-full min-w-[150px] lg:min-w-0">
                <i class="fa-solid fa-list-ul text-emerald-500 text-lg"></i>
                <span>Logs de Chat</span>
            </button>
            <button onclick="switchTab('config')" id="tab-config" class="tab-btn flex items-center gap-3 px-5 py-3.5 rounded-2xl glass-card text-left font-semibold w-full min-w-[150px] lg:min-w-0">
                <i class="fa-solid fa-gears text-amber-500 text-lg"></i>
                <span>Configuración</span>
            </button>
        </nav>

        <!-- CONTENT PANEL (Right Side) -->
        <section class="lg:col-span-3 space-y-6">

            <!-- TAB: PERSONALIDAD -->
            <div id="panel-personality" class="tab-panel space-y-6">
                <div class="glass-card p-7 rounded-[30px]">
                    <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-brain text-pink-500"></i>
                        Personalidad de la IA (Sin Reiniciar)
                    </h2>
                    <form id="personalityForm" class="space-y-4" onsubmit="savePersonality(event)">
                        <div>
                            <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Instrucción Principal del Sistema</label>
                            <textarea id="personality" name="personality" rows="4" class="w-full rounded-2xl bg-black/40 border border-white/10 px-4 py-3 text-white focus:border-pink-500 outline-none resize-none transition-colors"><%= aiConfig.personality %></textarea>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Tono Conversacional</label>
                                <input type="text" id="tone" name="tone" value="<%= aiConfig.tone %>" class="w-full rounded-2xl bg-black/40 border border-white/10 px-4 py-3 text-white focus:border-pink-500 outline-none transition-colors">
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Idioma</label>
                                <select id="language" name="language" class="w-full rounded-2xl bg-black/40 border border-white/10 px-4 py-3 text-white focus:border-pink-500 outline-none transition-colors appearance-none">
                                    <option value="es" <%= aiConfig.language === 'es' ? 'selected' : '' %>>Español</option>
                                    <option value="en" <%= aiConfig.language === 'en' ? 'selected' : '' %>>English</option>
                                    <option value="id" <%= aiConfig.language === 'id' ? 'selected' : '' %>>Indonesian</option>
                                    <option value="pt" <%= aiConfig.language === 'pt' ? 'selected' : '' %>>Portuguese</option>
                                </select>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Tokens Máximos</label>
                                <input type="number" id="maxLength" name="maxLength" value="<%= aiConfig.maxLength %>" class="w-full rounded-2xl bg-black/40 border border-white/10 px-4 py-3 text-white focus:border-pink-500 outline-none">
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Temperatura (Creatividad 0.0 - 1.0)</label>
                                <input type="number" step="0.1" id="creativity" name="creativity" value="<%= aiConfig.creativity %>" class="w-full rounded-2xl bg-black/40 border border-white/10 px-4 py-3 text-white focus:border-pink-500 outline-none">
                            </div>
                        </div>

                        <div class="border-t border-white/5 pt-5 space-y-4">
                            <h3 class="text-sm font-bold tracking-wider text-purple-400 uppercase">Configuración de Modelo</h3>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Proveedor</label>
                                    <select id="provider" name="provider" onchange="updateProviderModels()" class="w-full rounded-2xl bg-black/40 border border-white/10 px-4 py-3 text-white focus:border-pink-500 outline-none transition-colors">
                                        <option value="gemini" <%= aiConfig.provider === 'gemini' ? 'selected' : '' %>>Google Gemini</option>
                                        <option value="openrouter" <%= aiConfig.provider === 'openrouter' ? 'selected' : '' %>>OpenRouter</option>
                                        <option value="grok" <%= aiConfig.provider === 'grok' ? 'selected' : '' %>>xAI Grok</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Modelo</label>
                                    <input type="text" id="model" name="model" value="<%= aiConfig.model %>" class="w-full rounded-2xl bg-black/40 border border-white/10 px-4 py-3 text-white focus:border-pink-500 outline-none">
                                </div>
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">API Key del Proveedor (Opcional)</label>
                                <input type="password" id="apiKey" name="apiKey" value="<%= aiConfig.apiKey %>" placeholder="Utiliza variables de entorno si se deja vacío" class="w-full rounded-2xl bg-black/40 border border-white/10 px-4 py-3 text-white focus:border-pink-500 outline-none">
                            </div>
                        </div>

                        <div class="border-t border-white/5 pt-5">
                            <div class="flex items-center justify-between">
                                <div>
                                    <h3 class="text-sm font-bold text-indigo-400">Soporte MCP (Model Context Protocol)</h3>
                                    <p class="text-xs text-gray-400">Vincular bases de datos y herramientas externas a la IA.</p>
                                </div>
                                <label class="ios-switch">
                                    <input type="checkbox" id="mcpEnabled" name="mcpEnabled" <%= aiConfig.mcpEnabled ? 'checked' : '' %>>
                                    <span class="ios-slider"></span>
                                </label>
                            </div>

                            <div id="mcpServersSection" class="mt-4 space-y-3 <%= aiConfig.mcpEnabled ? '' : 'hidden' %>">
                                <div id="mcpServersList" class="space-y-2"></div>
                                <div class="flex gap-2">
                                    <input type="text" id="newMcpName" placeholder="Postgres DB" class="w-1/3 rounded-xl bg-black/30 border border-white/10 px-3 py-2 text-sm">
                                    <input type="text" id="newMcpUrl" placeholder="http://localhost:5001" class="w-2/3 rounded-xl bg-black/30 border border-white/10 px-3 py-2 text-sm">
                                    <button type="button" onclick="addMcpServer()" class="px-4 py-2 bg-gradient-to-tr from-pink-500 to-purple-600 rounded-xl text-sm font-bold flex items-center justify-center">
                                        <i class="fa-solid fa-plus"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="pt-4 flex justify-end">
                            <button type="submit" class="w-full sm:w-auto px-8 py-3.5 bg-gradient-to-r from-pink-500 via-purple-500 to-indigo-500 rounded-2xl font-bold tracking-wide shadow-lg shadow-pink-500/10">
                                Guardar Cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- TAB: AUTO-RESPUESTAS -->
            <div id="panel-autoresponses" class="tab-panel space-y-6 hidden">
                <div class="glass-card p-7 rounded-[30px]">
                    <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-reply text-purple-500"></i>
                        Respuestas Automáticas para Palabras Claves
                    </h2>

                    <!-- Config welcome and absence -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                        <div class="space-y-3">
                            <div class="flex items-center justify-between">
                                <label class="text-sm font-semibold text-purple-400">Modo de Ausencia</label>
                                <label class="ios-switch">
                                    <input type="checkbox" id="absenceMode" onchange="saveAutoResponseSettings()">
                                    <span class="ios-slider"></span>
                                </label>
                            </div>
                            <textarea id="absenceMessage" rows="2" class="w-full rounded-xl bg-black/40 border border-white/10 px-3 py-2 text-xs" placeholder="Mensaje de ausencia..."></textarea>
                        </div>
                        <div class="space-y-3">
                            <label class="text-sm font-semibold text-purple-400 block">Mensaje de Bienvenida Grupal (Por Defecto)</label>
                            <p class="text-[10px] text-gray-400">Actívalo por grupo activando "Welcome" en cada grupo de WhatsApp.</p>
                            <textarea readonly class="w-full rounded-xl bg-white/5 border border-white/5 px-3 py-2 text-xs text-gray-400">Se configura a través de comandos de WhatsApp y se envía automáticamente.</textarea>
                        </div>
                    </div>

                    <!-- Keywords List -->
                    <div class="border-t border-white/5 pt-5 space-y-4">
                        <h3 class="text-sm font-bold text-gray-300">Reglas de Palabras Clave</h3>
                        <div id="keywordsList" class="space-y-2"></div>

                        <!-- Add Rule -->
                        <form onsubmit="addKeywordRule(event)" class="grid grid-cols-1 sm:grid-cols-3 gap-2 items-end pt-2">
                            <div>
                                <label class="block text-xs text-gray-400 mb-1">Palabra Clave</label>
                                <input type="text" id="newKeyword" required placeholder="ej: soporte" class="w-full rounded-xl bg-black/30 border border-white/10 px-3 py-2.5 text-xs">
                            </div>
                            <div>
                                <label class="block text-xs text-gray-400 mb-1">Respuesta del Bot</label>
                                <input type="text" id="newResponse" required placeholder="Nuestra ayuda es en..." class="w-full rounded-xl bg-black/30 border border-white/10 px-3 py-2.5 text-xs">
                            </div>
                            <button type="submit" class="w-full py-2.5 bg-gradient-to-r from-purple-500 to-indigo-500 rounded-xl font-bold text-xs">
                                <i class="fa-solid fa-plus"></i> Añadir Palabra Clave
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- TAB: REGLAS -->
            <div id="panel-rules" class="tab-panel space-y-6 hidden">
                <div class="glass-card p-7 rounded-[30px]">
                    <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-scroll text-violet-500"></i>
                        Reglas y Comportamiento de la IA
                    </h2>
                    <div id="rulesList" class="space-y-3 mb-6"></div>

                    <div class="border-t border-white/5 pt-5">
                        <h3 class="text-sm font-bold text-gray-300 mb-3">Nueva Regla de IA</h3>
                        <form id="ruleForm" class="grid grid-cols-1 sm:grid-cols-3 gap-3 items-end" onsubmit="addRule(event)">
                            <div class="sm:col-span-2">
                                <label class="block text-xs text-gray-400 mb-1">Regla</label>
                                <input type="text" id="ruleText" required placeholder="Nunca hables de la competencia..." class="w-full rounded-2xl bg-black/30 border border-white/10 px-4 py-3 text-sm">
                            </div>
                            <div class="flex gap-2">
                                <div class="w-full">
                                    <label class="block text-xs text-gray-400 mb-1">Prioridad</label>
                                    <select id="rulePriority" class="w-full rounded-2xl bg-black/30 border border-white/10 px-3 py-3 text-sm">
                                        <option value="alta">Alta</option>
                                        <option value="media">Media</option>
                                        <option value="baja">Baja</option>
                                    </select>
                                </div>
                                <button type="submit" class="px-5 py-3 bg-gradient-to-tr from-violet-500 to-pink-500 rounded-2xl font-bold">
                                    <i class="fa-solid fa-plus"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- TAB: USUARIOS -->
            <div id="panel-users" class="tab-panel space-y-6 hidden">
                <div class="glass-card p-7 rounded-[30px]">
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-4">
                        <h2 class="text-xl font-bold flex items-center gap-2">
                            <i class="fa-solid fa-users text-indigo-500"></i>
                            Gestión de Usuarios Activos
                        </h2>
                        <input type="text" id="userSearch" placeholder="Buscar por número o nombre..." oninput="filterUsers()" class="rounded-xl bg-black/30 border border-white/10 px-3 py-1.5 text-xs w-full sm:w-48 outline-none">
                    </div>

                    <div class="overflow-x-auto rounded-2xl border border-white/5 bg-black/15 max-h-[400px] overflow-y-auto">
                        <table class="w-full text-left text-xs">
                            <thead class="bg-white/5 text-gray-400 uppercase tracking-wider font-semibold">
                                <tr>
                                    <th class="px-4 py-3">Nombre / Número</th>
                                    <th class="px-4 py-3">Interacciones</th>
                                    <th class="px-4 py-3">Rango / Nivel</th>
                                    <th class="px-4 py-3">Premium</th>
                                    <th class="px-4 py-3">Estado</th>
                                    <th class="px-4 py-3 text-right">Acción</th>
                                </tr>
                            </thead>
                            <tbody id="usersTableBody" class="divide-y divide-white/5"></tbody>
                        </table>
                    </div>
                </div>

                <!-- USER DIALOG FOR CHAT HISTORY -->
                <div id="userHistoryModal" class="glass-card p-6 rounded-3xl hidden">
                    <div class="flex justify-between items-center border-b border-white/10 pb-3 mb-4">
                        <h3 class="text-sm font-bold text-gray-300">Historial del Chat de IA</h3>
                        <button onclick="closeHistoryModal()" class="text-gray-400 hover:text-white"><i class="fa-solid fa-xmark"></i></button>
                    </div>
                    <div id="chatHistoryContainer" class="space-y-3 max-h-[350px] overflow-y-auto pr-1"></div>
                </div>
            </div>

            <!-- TAB: CONTACTOS -->
            <div id="panel-contacts" class="tab-panel space-y-6 hidden">
                <div class="glass-card p-7 rounded-[30px]">
                    <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-paper-plane text-cyan-500"></i>
                        Gestión de Prospección / Campañas
                    </h2>

                    <form id="contactForm" class="grid grid-cols-1 sm:grid-cols-3 gap-3 items-end mb-6" onsubmit="addContact(event)">
                        <div>
                            <label class="block text-xs text-gray-400 mb-1">Número de Teléfono</label>
                            <input type="text" id="contactNumber" required placeholder="521234567890" class="w-full rounded-2xl bg-black/30 border border-white/10 px-4 py-3 text-sm">
                        </div>
                        <div>
                            <label class="block text-xs text-gray-400 mb-1">Mensaje de Campaña</label>
                            <input type="text" id="contactMessage" placeholder="¿Cómo estás?" class="w-full rounded-2xl bg-black/30 border border-white/10 px-4 py-3 text-sm">
                        </div>
                        <button type="submit" class="w-full py-3.5 bg-gradient-to-r from-cyan-500 to-indigo-500 rounded-2xl font-bold text-sm">
                            <i class="fa-solid fa-user-plus"></i> Añadir Prospección
                        </button>
                    </form>

                    <div class="border-t border-white/5 pt-5">
                        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-4 gap-3">
                            <h3 class="text-sm font-bold text-gray-300">Lista de Contactos de Campaña</h3>
                            <button onclick="triggerProactiveMessages()" class="px-5 py-2.5 bg-green-500 hover:bg-green-600 text-white rounded-2xl text-xs font-bold transition-all flex items-center gap-2">
                                <i class="fa-solid fa-paper-plane"></i> Enviar Mensajes Pendientes
                            </button>
                        </div>

                        <div class="overflow-x-auto rounded-2xl border border-white/5 bg-black/10">
                            <table class="w-full text-left text-sm">
                                <thead class="bg-white/5 text-gray-400 uppercase text-xs font-bold">
                                    <tr>
                                        <th class="px-4 py-3">Número</th>
                                        <th class="px-4 py-3">Mensaje</th>
                                        <th class="px-4 py-3">Estado</th>
                                        <th class="px-4 py-3 text-right">Acción</th>
                                    </tr>
                                </thead>
                                <tbody id="contactsTableBody" class="divide-y divide-white/5"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TAB: STATS & TELEMETRY -->
            <div id="panel-stats" class="tab-panel space-y-6 hidden">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    <div class="glass-card p-5 rounded-2xl text-center">
                        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Activos Ahora</p>
                        <h3 class="text-2xl font-bold mt-1 text-pink-400" id="statActiveRightNow">0</h3>
                    </div>
                    <div class="glass-card p-5 rounded-2xl text-center">
                        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Interactuados Hoy</p>
                        <h3 class="text-2xl font-bold mt-1 text-purple-400" id="statMessagesToday">0</h3>
                    </div>
                    <div class="glass-card p-5 rounded-2xl text-center">
                        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Tiempo AI promedio</p>
                        <h3 class="text-2xl font-bold mt-1 text-cyan-400" id="statResponseTime">0s</h3>
                    </div>
                    <div class="glass-card p-5 rounded-2xl text-center">
                        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Total de Usuarios</p>
                        <h3 class="text-2xl font-bold mt-1 text-emerald-400" id="statTotalUsers">0</h3>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Graph Activity last 7 days -->
                    <div class="glass-card p-6 rounded-3xl">
                        <h2 class="text-sm font-bold mb-4 flex items-center gap-2">
                            <i class="fa-solid fa-chart-bar text-pink-500"></i> Actividad de Mensajes (Últimos 7 Días)
                        </h2>
                        <div class="h-44 flex items-end justify-between gap-1 pt-4 pb-1" id="activityGraph"></div>
                    </div>

                    <!-- Usage by hour -->
                    <div class="glass-card p-6 rounded-3xl">
                        <h2 class="text-sm font-bold mb-4 flex items-center gap-2">
                            <i class="fa-solid fa-clock text-cyan-500"></i> Distribución de Uso (24 Horas)
                        </h2>
                        <div class="h-44 flex items-end justify-between gap-0.5 pt-4 pb-1" id="hourlyGraph"></div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Top 5 Active Users -->
                    <div class="glass-card p-6 rounded-3xl space-y-3">
                        <h2 class="text-sm font-bold flex items-center gap-2">
                            <i class="fa-solid fa-trophy text-amber-400"></i> Top 5 Usuarios Más Activos
                        </h2>
                        <div id="topUsersList" class="divide-y divide-white/5 text-xs"></div>
                    </div>

                    <!-- Top 10 Most Used Words -->
                    <div class="glass-card p-6 rounded-3xl space-y-3">
                        <h2 class="text-sm font-bold flex items-center gap-2">
                            <i class="fa-solid fa-cloud text-pink-400"></i> Palabras Más Comunes (Filtro de stop-words)
                        </h2>
                        <div id="wordFrequencyCloud" class="flex flex-wrap gap-2 pt-2"></div>
                    </div>
                </div>
            </div>

            <!-- TAB: LOGS -->
            <div id="panel-logs" class="tab-panel space-y-6 hidden">
                <div class="glass-card p-7 rounded-[30px] space-y-4">
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                        <h2 class="text-xl font-bold flex items-center gap-2">
                            <i class="fa-solid fa-list-ul text-emerald-500"></i>
                            Monitoreo en Tiempo Real (Actualización en Vivo)
                        </h2>

                        <!-- Export options -->
                        <div class="flex gap-2 w-full sm:w-auto">
                            <button onclick="exportLogs('json')" class="px-4 py-1.5 bg-indigo-500/10 hover:bg-indigo-500/20 text-indigo-400 border border-indigo-500/15 rounded-xl text-xs font-semibold flex items-center gap-1">
                                <i class="fa-solid fa-file-code"></i> JSON
                            </button>
                            <button onclick="exportLogs('csv')" class="px-4 py-1.5 bg-green-500/10 hover:bg-green-500/20 text-green-400 border border-green-500/15 rounded-xl text-xs font-semibold flex items-center gap-1">
                                <i class="fa-solid fa-file-csv"></i> CSV
                            </button>
                        </div>
                    </div>

                    <!-- Search and log filtering -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <input type="text" id="logSearch" placeholder="Buscar por remitente o contenido..." oninput="filterLogs()" class="rounded-xl bg-black/30 border border-white/10 px-3 py-2 text-xs outline-none focus:border-emerald-500">
                        <select id="logTypeFilter" onchange="filterLogs()" class="rounded-xl bg-black/30 border border-white/10 px-3 py-2 text-xs outline-none focus:border-emerald-500">
                            <option value="all">Todos los Chats</option>
                            <option value="grupo">Grupo</option>
                            <option value="privado">Privado</option>
                        </select>
                    </div>

                    <div id="logsContainer" class="space-y-3 max-h-[500px] overflow-y-auto pr-2"></div>
                </div>
            </div>

            <!-- TAB: CONFIGURACION GENERAL -->
            <div id="panel-config" class="tab-panel space-y-6 hidden">
                <div class="glass-card p-7 rounded-[30px]">
                    <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-gears text-amber-500"></i>
                        Ajustes Generales de WhatsApp
                    </h2>
                    <form id="botConfigForm" class="space-y-4" onsubmit="saveBotConfig(event)">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Nombre del Bot</label>
                                <input type="text" id="botName" name="botName" value="<%= botName %>" class="w-full rounded-2xl bg-black/40 border border-white/10 px-4 py-3 text-white focus:border-amber-500 outline-none">
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Prefijo (Activation Prefix)</label>
                                <input type="text" id="botPrefix" name="botPrefix" value="<%= prefix %>" class="w-full rounded-2xl bg-black/40 border border-white/10 px-4 py-3 text-white focus:border-amber-500 outline-none">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 border-t border-white/5 pt-5">
                            <div class="flex items-center justify-between py-2">
                                <div>
                                    <h3 class="text-sm font-semibold">Estado de Respuestas AI</h3>
                                    <p class="text-xs text-gray-400">Responder interactivamente</p>
                                </div>
                                <label class="ios-switch">
                                    <input type="checkbox" id="botStatus" name="botStatus" <%= botStatus ? 'checked' : '' %>>
                                    <span class="ios-slider"></span>
                                </label>
                            </div>
                            <div class="flex items-center justify-between py-2">
                                <div>
                                    <h3 class="text-sm font-semibold">Activar Pairing Code</h3>
                                    <p class="text-xs text-gray-400">Vinculación por clave numérica</p>
                                </div>
                                <label class="ios-switch">
                                    <input type="checkbox" id="pairingState" name="pairingState" <%= pairingState ? 'checked' : '' %>>
                                    <span class="ios-slider"></span>
                                </label>
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Número de Vinculación (PAIRING_NUMBER)</label>
                            <input type="text" id="pairingNumber" name="pairingNumber" value="<%= pairingNumber %>" placeholder="ej: 521234567890" class="w-full rounded-2xl bg-black/40 border border-white/10 px-4 py-3 text-white focus:border-amber-500 outline-none">
                        </div>

                        <div id="pairingCodeCard" class="bg-pink-500/10 border border-pink-500/20 p-5 rounded-2xl <%= pairingCode ? '' : 'hidden' %>">
                            <p class="text-xs text-pink-400 font-bold uppercase tracking-wider mb-2">Código de Vinculación Generado</p>
                            <div class="flex items-center justify-between">
                                <span class="text-2xl font-mono tracking-widest font-extrabold text-pink-300" id="pairingCodeDisplay"><%= pairingCode %></span>
                                <button type="button" onclick="copyPairingCode()" class="px-4 py-2 bg-pink-500 hover:bg-pink-600 rounded-xl font-bold text-xs flex items-center gap-1.5">
                                    <i class="fa-solid fa-copy"></i> Copiar
                                </button>
                            </div>
                            <p class="text-[11px] text-gray-400 mt-2">Introduce este código en WhatsApp Web para vincular la cuenta.</p>
                        </div>

                        <div class="pt-5 flex flex-col sm:flex-row gap-3">
                            <button type="submit" class="w-full sm:w-auto px-8 py-3.5 bg-gradient-to-r from-amber-500 to-orange-500 rounded-2xl font-bold shadow-lg shadow-amber-500/10 hover:opacity-90 active:scale-95 text-sm transition-all">
                                Guardar Ajustes
                            </button>
                            <button type="button" onclick="restartBot()" class="w-full sm:w-auto px-8 py-3.5 bg-red-600/20 hover:bg-red-600/30 text-red-400 border border-red-500/20 rounded-2xl font-bold active:scale-95 text-sm flex items-center justify-center gap-2 transition-all">
                                <i class="fa-solid fa-power-off"></i> Reiniciar Bot
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </section>
    </main>

    <!-- TOAST NOTIFICATION STACK -->
    <div id="toastContainer" class="fixed bottom-6 right-6 z-50 space-y-2"></div>

    <script>
        let currentTab = 'personality';
        let rawLogs = [];
        let rawUsers = [];

        // ON LOAD INITIALIZATION
        document.addEventListener("DOMContentLoaded", () => {
            loadRules();
            loadContacts();
            loadMcpServers();
            loadAutoResponseSettings();

            // Poll for statistics, logs and state instantly on startup
            fetchTelemetryData();
            loadUsers();

            // Set up AJAX polling timers (every 3 seconds for active, real-time live update!)
            setInterval(fetchTelemetryData, 3000);
            setInterval(loadUsers, 4000);
        });

        // TABS SELECTOR
        function switchTab(tabId) {
            document.querySelectorAll(".tab-panel").forEach(panel => panel.classList.add("hidden"));
            document.querySelectorAll(".tab-btn").forEach(btn => btn.classList.remove("active"));

            document.getElementById(`panel-${tabId}`).classList.remove("hidden");
            document.getElementById(`tab-${tabId}`).classList.add("active");
            currentTab = tabId;

            if (tabId === 'stats') fetchTelemetryData();
            if (tabId === 'logs') fetchTelemetryData();
            if (tabId === 'users') loadUsers();
        }

        // SHOW POPUP TOAST
        function showToast(message, type = "success") {
            const toast = document.createElement("div");
            toast.className = `glass-card px-5 py-3.5 rounded-2xl flex items-center gap-2.5 shadow-lg border-l-4 ${type === 'success' ? 'border-l-green-500' : 'border-l-red-500'} transform translate-y-2 opacity-0 transition-all duration-300`;
            toast.innerHTML = `
                <i class="${type === 'success' ? 'fa-solid fa-circle-check text-green-400' : 'fa-solid fa-circle-exclamation text-red-400'}"></i>
                <span class="text-xs font-semibold">${message}</span>
            `;
            const container = document.getElementById("toastContainer");
            container.appendChild(toast);

            setTimeout(() => { toast.classList.remove("translate-y-2", "opacity-0"); }, 50);
            setTimeout(() => {
                toast.classList.add("opacity-0");
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // SAVE PERSONALITY IA
        async function savePersonality(e) {
            e.preventDefault();
            const formData = {
                personality: document.getElementById("personality").value,
                tone: document.getElementById("tone").value,
                language: document.getElementById("language").value,
                maxLength: parseInt(document.getElementById("maxLength").value),
                creativity: parseFloat(document.getElementById("creativity").value),
                provider: document.getElementById("provider").value,
                model: document.getElementById("model").value,
                apiKey: document.getElementById("apiKey").value,
                mcpEnabled: document.getElementById("mcpEnabled").checked
            };

            try {
                const res = await fetch("/api/personality", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(formData)
                });
                if (res.ok) {
                    showToast("¡Personalidad y modelo de IA guardados!");
                } else {
                    showToast("Error al guardar personalidad", "error");
                }
            } catch (err) {
                showToast("Error de red", "error");
            }
        }

        // SAVE BOT CONFIGURATION
        async function saveBotConfig(e) {
            e.preventDefault();
            const formData = {
                botName: document.getElementById("botName").value,
                prefix: document.getElementById("botPrefix").value,
                botStatus: document.getElementById("botStatus").checked,
                pairingState: document.getElementById("pairingState").checked,
                pairingNumber: document.getElementById("pairingNumber").value
            };

            try {
                const res = await fetch("/api/bot-config", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(formData)
                });
                if (res.ok) {
                    showToast("Ajustes del bot guardados con éxito.");
                    const data = await res.json();
                    if (data.pairingCode) {
                        document.getElementById("pairingCodeCard").classList.remove("hidden");
                        document.getElementById("pairingCodeDisplay").innerText = data.pairingCode;
                    } else {
                        document.getElementById("pairingCodeCard").classList.add("hidden");
                    }
                } else {
                    showToast("Error al guardar ajustes", "error");
                }
            } catch (e) {
                showToast("Error de red", "error");
            }
        }

        // REBOOT BOT COMMAND
        async function restartBot() {
            if (!confirm("¿Seguro de reiniciar Yoshida Bot? Se restablecerá la conexión de WhatsApp.")) return;
            try {
                const res = await fetch("/api/restart", { method: "POST" });
                if (res.ok) {
                    showToast("Enviando orden de reinicio... espera un momento.");
                }
            } catch (e) {
                showToast("Comando de reinicio ejecutado.");
            }
        }

        // AUTO-RESPONSES LOGIC
        async function loadAutoResponseSettings() {
            try {
                const res = await fetch("/api/auto-responses");
                const data = await res.json();

                document.getElementById("absenceMode").checked = data.absenceMode;
                document.getElementById("absenceMessage").value = data.absenceMessage;

                const listDiv = document.getElementById("keywordsList");
                listDiv.innerHTML = "";

                if (data.autoResponses.length === 0) {
                    listDiv.innerHTML = `<p class="text-xs text-gray-500 italic">No hay palabras clave registradas.</p>`;
                    return;
                }

                data.autoResponses.forEach((r, idx) => {
                    listDiv.innerHTML += `
                        <div class="glass-card px-4 py-3 rounded-xl flex items-center justify-between text-xs">
                            <div class="flex items-center gap-2">
                                <span class="bg-purple-500/10 text-purple-400 px-2 py-0.5 rounded font-bold uppercase">${r.keyword}</span>
                                <i class="fa-solid fa-arrow-right text-gray-500"></i>
                                <span class="text-gray-300">${r.response}</span>
                            </div>
                            <button onclick="deleteKeywordRule(${idx})" class="text-red-400 hover:text-red-500 p-1.5 rounded transition-colors">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </div>
                    `;
                });
            } catch (e) {
                console.error(e);
            }
        }

        async function saveAutoResponseSettings() {
            const payload = {
                absenceMode: document.getElementById("absenceMode").checked,
                absenceMessage: document.getElementById("absenceMessage").value
            };
            try {
                await fetch("/api/auto-responses", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload)
                });
                showToast("Configuración de ausencia guardada.");
            } catch (e) {
                showToast("Error al guardar reglas", "error");
            }
        }

        async function addKeywordRule(e) {
            e.preventDefault();
            const keyword = document.getElementById("newKeyword").value.trim();
            const response = document.getElementById("newResponse").value.trim();

            try {
                // Get current rules first
                const settingsRes = await fetch("/api/auto-responses");
                const data = await settingsRes.json();

                data.autoResponses.push({ keyword, response });

                const updateRes = await fetch("/api/auto-responses", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ autoResponses: data.autoResponses })
                });

                if (updateRes.ok) {
                    showToast("Palabra clave registrada con éxito!");
                    document.getElementById("newKeyword").value = "";
                    document.getElementById("newResponse").value = "";
                    loadAutoResponseSettings();
                }
            } catch (err) {
                showToast("Fallo al registrar palabra clave", "error");
            }
        }

        async function deleteKeywordRule(idx) {
            try {
                const settingsRes = await fetch("/api/auto-responses");
                const data = await settingsRes.json();

                data.autoResponses.splice(idx, 1);

                await fetch("/api/auto-responses", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ autoResponses: data.autoResponses })
                });
                showToast("Palabra clave eliminada.");
                loadAutoResponseSettings();
            } catch (err) {
                showToast("Error al eliminar", "error");
            }
        }

        // TELEMETRY & LIVE STATISTICS
        async function fetchTelemetryData() {
            try {
                const res = await fetch("/api/stats");
                const data = await res.json();

                // 1. Connection indicators
                const connIndicator = document.getElementById("connIndicator");
                const connText = document.getElementById("connText");
                if (data.isConnected) {
                    connIndicator.className = "w-2.5 h-2.5 rounded-full bg-green-500 pulse-dot inline-block";
                    connText.innerText = "WhatsApp Conectado";
                } else {
                    connIndicator.className = "w-2.5 h-2.5 rounded-full bg-red-500 pulse-dot inline-block";
                    connText.innerText = "WhatsApp Desconectado (Pendiente)";
                }

                // 2. Statistics panels
                document.getElementById("statActiveRightNow").innerText = data.activeUsersRightNow;
                document.getElementById("statMessagesToday").innerText = data.messagesToday;
                document.getElementById("statResponseTime").innerText = data.avgResponseTime;
                document.getElementById("statTotalUsers").innerText = data.totalUsers;

                // 3. Activity Graph last 7 days
                const activityGraph = document.getElementById("activityGraph");
                activityGraph.innerHTML = "";
                const days = data.graphData || [0,0,0,0,0,0,0];
                const maxDays = Math.max(...days, 5);
                const weekNames = ["Lun", "Mar", "Mié", "Jue", "Vie", "Sáb", "Dom"];

                days.forEach((val, idx) => {
                    const hPercent = Math.round((val / maxDays) * 100);
                    activityGraph.innerHTML += `
                        <div class="flex-1 flex flex-col items-center h-full justify-end">
                            <div class="w-full sm:w-8 bg-gradient-to-t from-purple-600 to-pink-500 rounded-t-lg text-[9px] font-bold text-white flex items-center justify-center shadow-lg shadow-pink-500/10" style="height: ${hPercent}%">
                                ${val > 0 ? val : ''}
                            </div>
                            <span class="text-[9px] text-gray-500 font-semibold mt-1">${weekNames[idx]}</span>
                        </div>
                    `;
                });

                // 4. Hourly distribution graph
                const hourlyGraph = document.getElementById("hourlyGraph");
                hourlyGraph.innerHTML = "";
                const hours = data.hoursDistribution || Array(24).fill(0);
                const maxHours = Math.max(...hours, 5);

                hours.forEach((val, idx) => {
                    const hPercent = Math.round((val / maxHours) * 100);
                    hourlyGraph.innerHTML += `
                        <div class="flex-1 flex flex-col items-center h-full justify-end" title="${idx}:00 - ${val} mensajes">
                            <div class="w-1.5 bg-gradient-to-t from-teal-500 to-cyan-400 rounded-t-full hover:opacity-80" style="height: ${hPercent}%"></div>
                            <span class="text-[7px] text-gray-500 font-semibold mt-1">${idx}h</span>
                        </div>
                    `;
                });

                // 5. Word frequency tags (Word Cloud representation)
                const cloud = document.getElementById("wordFrequencyCloud");
                cloud.innerHTML = "";
                if (data.topWords.length === 0) {
                    cloud.innerHTML = `<p class="text-xs text-gray-500 italic">Esperando telemetría de mensajes...</p>`;
                } else {
                    data.topWords.forEach(tw => {
                        const sizeClass = tw.count > 5 ? 'text-xs px-2.5 py-1.5 bg-pink-500/10 text-pink-400 border border-pink-500/15'
                                         : 'text-[10px] px-2 py-1 bg-white/5 text-gray-300 border border-white/5';
                        cloud.innerHTML += `
                            <span class="rounded-full font-semibold ${sizeClass}">${tw.word} (${tw.count})</span>
                        `;
                    });
                }

                // 6. Top 5 active users list
                const topUsers = document.getElementById("topUsersList");
                topUsers.innerHTML = "";
                if (data.top5Users.length === 0) {
                    topUsers.innerHTML = `<p class="text-xs text-gray-500 italic py-2">No hay estadísticas de usuarios...</p>`;
                } else {
                    data.top5Users.forEach((u, i) => {
                        topUsers.innerHTML += `
                            <div class="flex items-center justify-between py-2.5">
                                <div class="flex items-center gap-2">
                                    <span class="w-5 h-5 rounded-full bg-amber-500/15 text-amber-400 flex items-center justify-center font-bold text-[10px]">${i + 1}</span>
                                    <div>
                                        <p class="font-bold text-gray-200">@${u.name}</p>
                                        <p class="text-[9px] text-gray-500 font-mono">${u.jid}</p>
                                    </div>
                                </div>
                                <span class="font-bold text-pink-400 bg-pink-500/10 px-2 py-0.5 rounded">${u.hit} hits</span>
                            </div>
                        `;
                    });
                }

                // 7. Update raw logs for live feed
                await loadLogs();

            } catch (err) {
                console.error("Error polling telemetry:", err);
            }
        }

        // USERS MANAGEMENT & CHAT HISTORY
        async function loadUsers() {
            try {
                const res = await fetch("/api/users");
                rawUsers = await res.json();
                filterUsers();
            } catch (e) {
                console.error(e);
            }
        }

        function filterUsers() {
            const query = document.getElementById("userSearch").value.toLowerCase();
            const body = document.getElementById("usersTableBody");
            body.innerHTML = "";

            const filtered = rawUsers.filter(u => u.name.toLowerCase().includes(query) || u.jid.toLowerCase().includes(query));

            if (filtered.length === 0) {
                body.innerHTML = `<tr><td colspan="6" class="px-4 py-8 text-center text-gray-500 italic">No se encontraron usuarios coincidentes.</td></tr>`;
                return;
            }

            filtered.forEach(u => {
                const activeState = u.banned ? 'Baneado' : 'Activo';
                const premiumBadge = u.premium ? 'Si <i class="fa-solid fa-star text-amber-400"></i>' : 'No';

                body.innerHTML += `
                    <tr class="hover:bg-white/5 transition-colors">
                        <td class="px-4 py-3 font-semibold text-gray-200">
                            <div>@${u.name}</div>
                            <div class="text-[9px] text-gray-500 font-mono">${u.jid}</div>
                        </td>
                        <td class="px-4 py-3 font-bold">${u.hit}</td>
                        <td class="px-4 py-3">
                            <span class="bg-indigo-500/10 text-indigo-400 px-2.5 py-0.5 rounded text-[9px] uppercase font-bold">Nivel ${u.level}</span>
                        </td>
                        <td class="px-4 py-3">
                            <button onclick="togglePremium('${u.jid}')" class="px-2.5 py-1 rounded-xl bg-white/5 hover:bg-white/10 text-[10px] font-bold text-gray-300">
                                ${premiumBadge}
                            </button>
                        </td>
                        <td class="px-4 py-3">
                            <span class="px-2 py-0.5 rounded text-[9px] font-extrabold uppercase ${u.banned ? 'bg-red-500/10 text-red-400 border border-red-500/20' : 'bg-green-500/10 text-green-400 border border-green-500/20'}">
                                ${activeState}
                            </span>
                        </td>
                        <td class="px-4 py-3 text-right space-x-1">
                            <button onclick="viewChatHistory('${u.jid}', '${u.name}')" class="text-indigo-400 hover:text-indigo-300 px-2 py-1 hover:bg-indigo-500/5 rounded-lg text-[10px] font-bold">
                                <i class="fa-solid fa-comments"></i> Chat
                            </button>
                            <button onclick="${u.banned ? `unblockUser('${u.jid}')` : `blockUser('${u.jid}')`}" class="${u.banned ? 'text-green-400 hover:text-green-300' : 'text-red-400 hover:text-red-300'} px-2 py-1 rounded-lg text-[10px] font-bold">
                                <i class="fa-solid ${u.banned ? 'fa-user-check' : 'fa-user-slash'}"></i>
                            </button>
                        </td>
                    </tr>
                `;
            });
        }

        async function togglePremium(jid) {
            try {
                const res = await fetch("/api/users/toggle-premium", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ jid })
                });
                if (res.ok) {
                    showToast("Membresía premium modificada.");
                    loadUsers();
                }
            } catch (err) {
                showToast("Fallo al cambiar premium", "error");
            }
        }

        async function blockUser(jid) {
            try {
                await fetch("/api/users/block", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ jid })
                });
                showToast("Usuario baneado con éxito.");
                loadUsers();
            } catch (e) {
                showToast("Fallo al banear usuario", "error");
            }
        }

        async function unblockUser(jid) {
            try {
                await fetch("/api/users/unblock", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ jid })
                });
                showToast("Usuario desbloqueado.");
                loadUsers();
            } catch (e) {
                showToast("Fallo al desbloquear usuario", "error");
            }
        }

        async function viewChatHistory(jid, name) {
            try {
                const res = await fetch(`/api/users/history/${encodeURIComponent(jid)}`);
                const history = await res.json();

                const modal = document.getElementById("userHistoryModal");
                const container = document.getElementById("chatHistoryContainer");

                modal.classList.remove("hidden");
                container.innerHTML = "";

                if (history.length === 0) {
                    container.innerHTML = `<p class="text-xs text-gray-500 italic text-center py-6">No hay historial de IA registrado para este usuario.</p>`;
                    return;
                }

                history.forEach(h => {
                    const isUser = h.role === 'user';
                    container.innerHTML += `
                        <div class="flex ${isUser ? 'justify-end' : 'justify-start'} w-full text-xs">
                            <div class="p-3 rounded-2xl max-w-[80%] ${isUser ? 'bg-pink-600/20 text-pink-100 rounded-tr-none' : 'bg-white/5 text-gray-200 rounded-tl-none'}">
                                <p class="font-extrabold text-[9px] uppercase ${isUser ? 'text-pink-400' : 'text-purple-400'} mb-1">${isUser ? 'Usuario' : 'AI Assistant'}</p>
                                <p class="font-medium whitespace-pre-wrap">${h.content}</p>
                            </div>
                        </div>
                    `;
                });

                container.scrollTop = container.scrollHeight;
            } catch (err) {
                showToast("Error al cargar historial", "error");
            }
        }

        function closeHistoryModal() {
            document.getElementById("userHistoryModal").classList.add("hidden");
        }

        // REAL-TIME LOGGING
        async function loadLogs() {
            try {
                const res = await fetch("/api/logs");
                rawLogs = await res.json();
                filterLogs();
            } catch (err) {
                console.error(err);
            }
        }

        function filterLogs() {
            const query = document.getElementById("logSearch").value.toLowerCase();
            const filterType = document.getElementById("logTypeFilter").value;
            const container = document.getElementById("logsContainer");
            container.innerHTML = "";

            const filtered = rawLogs.filter(log => {
                const searchStr = log.user + " " + log.message + " " + log.response;
                const matchesSearch = searchStr.toLowerCase().includes(query);
                const matchesType = filterType === 'all' || log.type === filterType;
                return matchesSearch && matchesType;
            });

            if (filtered.length === 0) {
                container.innerHTML = `<p class="text-xs text-gray-500 italic text-center py-6">No hay registros que coincidan.</p>`;
                return;
            }

            filtered.forEach(log => {
                const formatTime = new Date(log.timestamp).toLocaleTimeString();
                const typeBadge = log.type === 'grupo' ? 'bg-cyan-500/10 text-cyan-400 border border-cyan-500/20' : 'bg-pink-500/10 text-pink-400 border border-pink-500/20';

                container.innerHTML += `
                    <div class="glass-card p-4 rounded-2xl space-y-2 text-xs">
                        <div class="flex justify-between items-center border-b border-white/5 pb-1.5">
                            <div class="flex items-center gap-2">
                                <span class="font-bold text-pink-400">@${log.user}</span>
                                <span class="px-2 py-0.5 rounded text-[9px] uppercase tracking-wider font-extrabold ${typeBadge}">${log.type}</span>
                                ${log.responseTime ? `<span class="bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 px-2 py-0.5 rounded text-[9px] font-bold"><i class="fa-solid fa-bolt"></i> ${(log.responseTime / 1000).toFixed(2)}s</span>` : ''}
                            </div>
                            <span class="text-gray-500 font-semibold">${formatTime}</span>
                        </div>
                        <div class="space-y-1">
                            <p class="text-gray-300"><strong class="text-gray-500">M:</strong> ${log.message || '<em class="text-gray-600 font-light">Mensaje no textual</em>'}</p>
                            ${log.response ? `<p class="text-pink-100 font-medium"><strong class="text-purple-400">R:</strong> ${log.response}</p>` : '<p class="text-gray-500 italic font-light"><strong class="text-gray-500">R:</strong> Procesando o respondido manualmente...</p>'}
                        </div>
                    </div>
                `;
            });
        }

        function exportLogs(format) {
            window.location.href = `/api/logs/export?format=${format}`;
        }

        // RULES MANAGEMENT
        async function loadRules() {
            try {
                const res = await fetch("/api/rules");
                const rules = await res.json();
                const container = document.getElementById("rulesList");
                container.innerHTML = "";

                if (rules.length === 0) {
                    container.innerHTML = `<p class="text-xs text-gray-500 italic text-center py-4">No hay reglas registradas.</p>`;
                    return;
                }

                rules.forEach(rule => {
                    const badgeClass = rule.priority === 'alta' ? 'bg-red-500/10 text-red-400 border border-red-500/20'
                                      : rule.priority === 'media' ? 'bg-amber-500/10 text-amber-400 border border-amber-500/20'
                                      : 'bg-indigo-500/10 text-indigo-400 border border-indigo-500/20';

                    container.innerHTML += `
                        <div class="glass-card px-4 py-3 rounded-2xl flex items-center justify-between gap-3 text-xs">
                            <div class="flex items-center gap-3">
                                <span class="text-[9px] px-2 py-0.5 rounded font-bold uppercase tracking-wider ${badgeClass}">${rule.priority}</span>
                                <p class="font-medium text-gray-200">${rule.text}</p>
                            </div>
                            <button onclick="deleteRule('${rule.id}')" class="text-red-400 hover:text-red-500 p-1.5 rounded transition-colors">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </div>
                    `;
                });
            } catch (err) {
                console.error("Error rules:", err);
            }
        }

        async function addRule(e) {
            e.preventDefault();
            const text = document.getElementById("ruleText").value;
            const priority = document.getElementById("rulePriority").value;

            try {
                const res = await fetch("/api/rules", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ text, priority })
                });
                if (res.ok) {
                    showToast("Regla registrada de forma segura.");
                    document.getElementById("ruleText").value = "";
                    loadRules();
                }
            } catch (err) {
                showToast("Error de red", "error");
            }
        }

        async function deleteRule(id) {
            try {
                const res = await fetch(`/api/rules/${id}`, { method: "DELETE" });
                if (res.ok) {
                    showToast("Regla de IA eliminada.");
                    loadRules();
                }
            } catch (err) {
                showToast("Fallo al eliminar", "error");
            }
        }

        // CONTACTS CAMPAIGNS MANAGEMENT
        async function loadContacts() {
            try {
                const res = await fetch("/api/contacts");
                const contacts = await res.json();
                const body = document.getElementById("contactsTableBody");
                body.innerHTML = "";

                if (contacts.length === 0) {
                    body.innerHTML = `<tr><td colspan="4" class="px-4 py-6 text-center text-gray-500 italic text-xs">No hay prospecciones de campaña.</td></tr>`;
                    return;
                }

                contacts.forEach(c => {
                    const statusClass = c.status === 'respondido' ? 'bg-green-500/10 text-green-400 border border-green-500/20'
                                      : c.status === 'enviado' ? 'bg-blue-500/10 text-blue-400 border border-blue-500/20'
                                      : 'bg-yellow-500/10 text-yellow-400 border border-yellow-500/20';

                    body.innerHTML += `
                        <tr class="hover:bg-white/5 text-xs transition-colors">
                            <td class="px-4 py-2.5 font-bold">${c.number}</td>
                            <td class="px-4 py-2.5 text-gray-400">${c.message || '<em class="text-gray-600">Por defecto</em>'}</td>
                            <td class="px-4 py-2.5">
                                <span class="px-2 py-0.5 rounded text-[9px] font-bold uppercase tracking-wider ${statusClass}">${c.status}</span>
                            </td>
                            <td class="px-4 py-2.5 text-right">
                                <button onclick="deleteContact('${c.id}')" class="text-red-400 hover:text-red-500 p-1.5 rounded transition-colors">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                });
            } catch (err) {
                console.error(err);
            }
        }

        async function addContact(e) {
            e.preventDefault();
            const number = document.getElementById("contactNumber").value;
            const message = document.getElementById("contactMessage").value;

            try {
                await fetch("/api/contacts", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ number, message })
                });
                showToast("Prospección guardada.");
                document.getElementById("contactNumber").value = "";
                document.getElementById("contactMessage").value = "";
                loadContacts();
            } catch (e) {
                showToast("Fallo al agregar contacto", "error");
            }
        }

        async function deleteContact(id) {
            try {
                await fetch(`/api/contacts/${id}`, { method: "DELETE" });
                showToast("Prospección de campaña eliminada.");
                loadContacts();
            } catch (e) {
                showToast("Fallo al eliminar", "error");
            }
        }

        async function triggerProactiveMessages() {
            try {
                const res = await fetch("/api/contacts/send", { method: "POST" });
                if (res.ok) {
                    showToast("Campaña iniciada con éxito en segundo plano.");
                    setTimeout(loadContacts, 2000);
                } else {
                    showToast("No se pudo iniciar el envío masivo.", "error");
                }
            } catch (e) {
                showToast("Fallo de red", "error");
            }
        }

        // MCP SERVERS INTERFACES
        async function loadMcpServers() {
            try {
                const res = await fetch("/api/mcp-servers");
                const servers = await res.json();
                const container = document.getElementById("mcpServersList");
                container.innerHTML = "";

                if (servers.length === 0) {
                    container.innerHTML = `<p class="text-xs text-gray-500 italic py-1">No hay vinculaciones MCP de base de datos activas.</p>`;
                    return;
                }

                servers.forEach((srv, idx) => {
                    container.innerHTML += `
                        <div class="flex items-center justify-between bg-white/5 border border-white/5 p-3 rounded-xl text-xs">
                            <div class="flex items-center gap-2">
                                <span class="w-2 h-2 rounded-full bg-cyan-400 pulse-dot"></span>
                                <strong class="text-gray-300">${srv.name}</strong>
                                <span class="text-gray-500 font-mono text-[10px]">(${srv.url})</span>
                            </div>
                            <button type="button" onclick="deleteMcpServer(${idx})" class="text-red-400 hover:text-red-500 p-1.5 rounded transition-colors">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </div>
                    `;
                });
            } catch (e) {
                console.error(e);
            }
        }

        async function addMcpServer() {
            const name = document.getElementById("newMcpName").value.trim();
            const url = document.getElementById("newMcpUrl").value.trim();

            if (!name || !url) {
                showToast("Define el nombre y la url del servidor", "error");
                return;
            }

            try {
                await fetch("/api/mcp-servers", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ name, url })
                });
                showToast("Servidor MCP enlazado.");
                document.getElementById("newMcpName").value = "";
                document.getElementById("newMcpUrl").value = "";
                loadMcpServers();
            } catch (e) {
                showToast("Error de conexión", "error");
            }
        }

        async function deleteMcpServer(index) {
            try {
                await fetch(`/api/mcp-servers/${index}`, { method: "DELETE" });
                showToast("Vínculo MCP eliminado.");
                loadMcpServers();
            } catch (e) {
                showToast("Fallo al eliminar", "error");
            }
        }

        // PROVIDER AND PAIRING CODE HELPERS
        function updateProviderModels() {
            const provider = document.getElementById("provider").value;
            const modelInput = document.getElementById("model");
            if (provider === 'gemini') {
                modelInput.value = 'gemini-2.0-flash';
            } else if (provider === 'openrouter') {
                modelInput.value = 'google/gemini-2.0-flash';
            } else if (provider === 'grok') {
                modelInput.value = 'grok-2-1212';
            }
        }

        function copyPairingCode() {
            const code = document.getElementById("pairingCodeDisplay").innerText;
            navigator.clipboard.writeText(code);
            showToast("Código de Vinculación copiado!");
        }

        document.getElementById("mcpEnabled").addEventListener("change", (e) => {
            const s = document.getElementById("mcpServersSection");
            if (e.target.checked) s.classList.remove("hidden");
            else s.classList.add("hidden");
        });
    </script>
</body>
</html>
