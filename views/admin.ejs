        async function addSchedule(e) {
            e.preventDefault();
            const timeStr = document.getElementById("scheduleTime").value;
            const message = document.getElementById("scheduleMessage").value;

            if (!timeStr) return;

            const time = new Date(timeStr).getTime();
            if (time <= Date.now()) {
                showToast("Elige una fecha y hora futura.", "error");
                return;
            }

            try {
                await fetch("/api/schedules", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ time, message })
                });
                showToast("Mensaje programado correctamente!");
                document.getElementById("scheduleTime").value = "";
                document.getElementById("scheduleMessage").value = "";
                loadSchedules();
            } catch (err) {
                showToast("Error de conexión", "error");
            }
        }

        async function deleteSchedule(id) {
            try {
                await fetch(`/api/schedules/${id}`, { method: "DELETE" });
                showToast("Mensaje programado eliminado.");
                loadSchedules();
            } catch (e) {
                showToast("Error de conexión", "error");
            }
        }

